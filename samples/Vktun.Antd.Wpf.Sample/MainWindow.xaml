<Window x:Class="Vktun.Antd.Wpf.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:antd="clr-namespace:Vktun.Antd.Wpf;assembly=Vktun.Antd.Wpf"
        mc:Ignorable="d"
        Title="Vktun Antd WPF Catalog"
        Width="1480"
        Height="960"
        MinWidth="1240"
        MinHeight="780"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="CatalogNavigationListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="CatalogNavigationListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="14,13"
                                Background="#00FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgSpotlight}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgSpotlight}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowBackdrop" />
        <Rectangle x:Name="PatternOverlay"
                   Opacity="0.18"
                   IsHitTestVisible="False" />

        <Canvas IsHitTestVisible="False">
            <Ellipse x:Name="TopLeftGlow"
                     Width="420"
                     Height="420"
                     Canvas.Left="-120"
                     Canvas.Top="-90"
                     Opacity="0.85" />
            <Ellipse x:Name="BottomRightGlow"
                     Width="520"
                     Height="520"
                     Canvas.Right="-100"
                     Canvas.Bottom="-120"
                     Opacity="0.65" />
        </Canvas>

        <Grid Margin="32">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ThemeRail"
                    Padding="22"
                    CornerRadius="30"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="Bold" Text="组件目录" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                   Text="按 Ant Design 官方分类组织 sample，同时展示 WPF 映射、主题切换和最小可用片段。"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,20,0,18"
                            Padding="14"
                            Background="{DynamicResource Antd.Brush.FillSecondary}"
                            CornerRadius="18">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold" Text="分类导航" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="总览页包含组件覆盖矩阵，其余页面按分类拆成独立 UserControl。"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <ListBox x:Name="NavigationListBox"
                             Grid.Row="2"
                             Style="{StaticResource CatalogNavigationListBoxStyle}"
                             ItemContainerStyle="{StaticResource CatalogNavigationListBoxItemStyle}"
                             SelectionChanged="NavigationListBox_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="{Binding Title}" />
                                    <TextBlock Margin="0,5,0,0"
                                               FontSize="12.5"
                                               Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                               Text="{Binding Caption}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="3">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="当前预设" />
                        <TextBlock x:Name="ThemeFooterTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                   Text="切换顶部主题预设后，可以直接检查目录页、弹层和代码示例在不同主题下的表现。"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="PreviewShell"
                    Grid.Column="2"
                    Padding="28"
                    CornerRadius="34"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="ThemeHeroTitleTextBlock"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Text="Default Light" />
                            <TextBlock x:Name="ThemeHeroDescriptionTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="切换主题预设后，右侧目录页中的所有组件、弹层和代码片段区都会随当前资源刷新。"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Width="280">
                            <TextBlock Margin="0,0,0,8"
                                       FontWeight="SemiBold"
                                       Text="主题预设" />
                            <antd:ComboBox x:Name="ThemePresetSelector"
                                           SelectionChanged="ThemePresetSelector_OnSelectionChanged"
                                           Size="Small">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock FontWeight="SemiBold"
                                                       Text="{Binding Name}" />
                                            <TextBlock FontSize="12"
                                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                       Text="{Binding Caption}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </antd:ComboBox>

                            <WrapPanel Margin="0,14,0,0"
                                       HorizontalAlignment="Right">
                                <antd:Tag x:Name="ThemeCountTag" Margin="0,0,8,8" Content="0 个预设" />
                                <antd:Tag x:Name="ThemeModeTag" Margin="0,0,8,8" Content="Light" />
                                <antd:Tag x:Name="ThemePrimaryTag" Margin="0,0,8,8" Content="#1677FF" />
                                <antd:Tag x:Name="ThemeShapeTag" Margin="0,0,0,8" Content="10px 圆角" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,24,0,0"
                            Background="{DynamicResource Antd.Brush.BgContainer}"
                            BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                            BorderThickness="1"
                            CornerRadius="24">
                        <ContentControl x:Name="PageHost" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
