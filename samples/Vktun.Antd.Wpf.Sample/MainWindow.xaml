<Window x:Class="Vktun.Antd.Wpf.Sample.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:antd="clr-namespace:Vktun.Antd.Wpf;assembly=Vktun.Antd.Wpf"
        mc:Ignorable="d"
        Title="Vktun Antd WPF Sample"
        Width="1380"
        Height="900"
        MinWidth="1220"
        MinHeight="760"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style x:Key="ThemePresetListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="ThemePresetListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Padding="14,13"
                                Background="#00FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgSpotlight}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgSpotlight}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewSectionBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="14,12" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.BorderSecondary}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="WindowBackdrop" />
        <Canvas IsHitTestVisible="False">
            <Ellipse x:Name="TopLeftGlow"
                     Width="420"
                     Height="420"
                     Canvas.Left="-120"
                     Canvas.Top="-90"
                     Opacity="0.85" />
            <Ellipse x:Name="BottomRightGlow"
                     Width="520"
                     Height="520"
                     Canvas.Right="-100"
                     Canvas.Bottom="-120"
                     Opacity="0.65" />
        </Canvas>

        <Grid Margin="36">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="236" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ThemeRail"
                    Padding="20"
                    CornerRadius="30"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="24" FontWeight="Bold" Text="主题画廊" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                   Text="参考 Ant Design 首页主题展区，提供更多可切换的视觉预设。" />
                    </StackPanel>

                    <ListBox x:Name="ThemePresetListBox"
                             Grid.Row="1"
                             Margin="0,20,0,16"
                             Style="{StaticResource ThemePresetListBoxStyle}"
                             ItemContainerStyle="{StaticResource ThemePresetListBoxItemStyle}"
                             SelectionChanged="ThemePresetListBox_OnSelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding Name}" />
                                        <TextBlock Margin="0,5,0,0"
                                                   FontSize="12.5"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="{Binding Caption}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            VerticalAlignment="Top"
                                            Padding="8,3"
                                            Background="{DynamicResource Antd.Brush.FillSecondary}"
                                            CornerRadius="999">
                                        <TextBlock FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="{Binding ModeText}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2">
                        <TextBlock FontSize="16" FontWeight="SemiBold" Text="AI 生成主题" />
                        <TextBlock x:Name="ThemeFooterTextBlock"
                                   Margin="0,8,0,0"
                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                   Text="用一句话描述你想要的风格，再把它沉淀成新的主题预设。"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="PreviewShell"
                    Grid.Column="2"
                    Padding="30"
                    CornerRadius="34"
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="ThemeHeroTitleTextBlock"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Text="默认风格" />
                            <TextBlock x:Name="ThemeHeroDescriptionTextBlock"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="默认 Ant Design 语义色、柔和背景与通用圆角，适合作为所有业务页面的基线主题。"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <WrapPanel Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Top">
                            <antd:Tag x:Name="ThemeCountTag" Margin="0,0,8,8">0 套主题</antd:Tag>
                            <antd:Tag x:Name="ThemeModeTag" Margin="0,0,8,8">Light</antd:Tag>
                            <antd:Tag x:Name="ThemePrimaryTag" Margin="0,0,8,8">#1677FF</antd:Tag>
                            <antd:Tag x:Name="ThemeShapeTag" Margin="0,0,0,8">10px 圆角</antd:Tag>
                        </WrapPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="0,24,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <Border x:Name="ModalPreviewCard"
                                    Padding="20"
                                    BorderThickness="1"
                                    CornerRadius="26"
                                    Margin="0,0,0,18">
                                <StackPanel antd:SpaceAssist.Gap="16">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock FontSize="18"
                                                   FontWeight="Bold"
                                                   Text="Ant Design" />
                                        <Button DockPanel.Dock="Right"
                                                Width="36"
                                                Height="36"
                                                Content="×"
                                                antd:ButtonAssist.Type="Text" />
                                    </DockPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Text="Ant Design 使用 CSS-in-JS 技术以提供动态与混合主题的能力。与此同时，我们使用组件级别的 CSS-in-JS 解决方案，让你的应用获得更好的性能。" />
                                    <StackPanel Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                antd:SpaceAssist.Gap="10">
                                        <Button Content="取消" />
                                        <Button Content="确定"
                                                antd:ButtonAssist.Type="Primary" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border x:Name="InfoBannerBorder"
                                    Style="{StaticResource PreviewSectionBorderStyle}"
                                    Background="{DynamicResource Antd.Brush.BgSpotlight}">
                                <TextBlock FontWeight="SemiBold" Text="信息内容展示" />
                            </Border>

                            <Border Style="{StaticResource PreviewSectionBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="下拉框样式" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="支持描边、填充和无边框三种样式，可直接切换预览。" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                antd:SpaceAssist.Gap="12">
                                        <TextBlock VerticalAlignment="Center"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="当前样式" />
                                        <ComboBox x:Name="ComboBoxVariantSelector"
                                                  Width="132"
                                                  SelectedIndex="0"
                                                  SelectionChanged="ComboBoxVariantSelector_OnSelectionChanged"
                                                  antd:ControlAssist.Size="Small">
                                            <ComboBoxItem Content="描边" Tag="{x:Static antd:AntdComboBoxVariant.Outlined}" />
                                            <ComboBoxItem Content="填充" Tag="{x:Static antd:AntdComboBoxVariant.Filled}" />
                                            <ComboBoxItem Content="无边框" Tag="{x:Static antd:AntdComboBoxVariant.Borderless}" />
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <WrapPanel Margin="0,0,0,14">
                                <ComboBox x:Name="PreviewCategoryComboBox" Width="156" Margin="0,0,12,12" SelectedIndex="0">
                                    <ComboBoxItem Content="下拉菜单" />
                                    <ComboBoxItem Content="主题预设" />
                                    <ComboBoxItem Content="运行时切换" />
                                </ComboBox>
                                <TextBox Width="136"
                                         Margin="0,0,12,12"
                                         Text="#1677FF" />
                                <ComboBox x:Name="PreviewTagComboBox" Width="240" Margin="0,0,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="苹果  x    香蕉  x" />
                                    <ComboBoxItem Content="青柠  x    橙子  x" />
                                </ComboBox>
                                <DatePicker Width="176" Margin="0,0,12,12" />
                                <ComboBox x:Name="PreviewFruitComboBox" Width="340" Margin="0,0,0,12" SelectedIndex="0">
                                    <ComboBoxItem Content="苹果  x    香蕉  x" />
                                    <ComboBoxItem Content="可可  x    牛油果  x" />
                                </ComboBox>
                            </WrapPanel>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ProgressBar Height="10"
                                             Margin="0,4,12,0"
                                             Value="60"
                                             Maximum="100" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Text="60%" />
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Border Width="34"
                                            Height="34"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Antd.Brush.BgSpotlight}"
                                            CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Antd.Brush.Primary}"
                                                   Text="OK" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="已完成" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Border Width="34"
                                            Height="34"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Antd.Brush.Primary}"
                                            CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Antd.Brush.White}"
                                                   Text="2" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="进行中" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <Border Width="34"
                                            Height="34"
                                            Margin="0,0,12,0"
                                            Background="{DynamicResource Antd.Brush.FillSecondary}"
                                            CornerRadius="999">
                                        <TextBlock HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Bold"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="3" />
                                    </Border>
                                    <TextBlock VerticalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                               Text="等待中" />
                                </StackPanel>
                            </Grid>

                            <Slider Margin="0,0,0,22"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="54" />

                            <WrapPanel Margin="0,0,0,16">
                                <Button Margin="0,0,12,12"
                                        Content="主要按钮"
                                        Width="112"
                                        antd:ButtonAssist.Type="Primary" />
                                <Button Margin="0,0,12,12"
                                        Content="危险按钮"
                                        Width="112"
                                        Background="{DynamicResource Antd.Brush.Error}"
                                        Foreground="{DynamicResource Antd.Brush.White}" />
                                <Button Margin="0,0,12,12"
                                        Content="默认按钮"
                                        Width="112" />
                                <Button Margin="0,0,0,12"
                                        Content="虚线按钮"
                                        Width="112"
                                        antd:ButtonAssist.Type="Dashed" />
                            </WrapPanel>

                            <StackPanel Margin="0,0,0,16"
                                        Orientation="Horizontal"
                                        antd:SpaceAssist.Gap="18">
                                <antd:Switch IsChecked="True" />
                                <CheckBox Content="苹果" IsChecked="True" />
                                <CheckBox Content="香蕉" />
                                <CheckBox Content="橘子" />
                                <RadioButton GroupName="fruits" Content="苹果" IsChecked="True" />
                                <RadioButton GroupName="fruits" Content="香蕉" />
                            </StackPanel>

                            <WrapPanel Margin="0,0,0,16">
                                <Button Margin="0,0,8,8"
                                        Content="A"
                                        Width="42"
                                        antd:ButtonAssist.Type="Primary" />
                                <Button Margin="0,0,8,8"
                                        Content="B"
                                        Width="42" />
                                <Button Margin="0,0,16,8"
                                        Content="C"
                                        Width="42" />
                                <Button Margin="0,0,8,8" Content="每日" />
                                <Button Margin="0,0,8,8" Content="每周" />
                                <Button Margin="0,0,8,8" Content="每月" />
                            </WrapPanel>

                            <Border Style="{StaticResource PreviewSectionBorderStyle}"
                                    Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Text="交互服务" />
                                        <TextBlock Margin="0,6,0,0"
                                                   Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                   Text="继续保留消息、通知与弹窗服务，并补充独立窗体模态框以验证新窗口场景。" />
                                    </StackPanel>
                                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                        <Button Margin="0,0,8,8"
                                                Content="Success"
                                                antd:ButtonAssist.Type="Primary"
                                                Click="ShowSuccessMessageButton_OnClick" />
                                        <Button Margin="0,0,8,8"
                                                Content="Warning"
                                                antd:ButtonAssist.Type="Dashed"
                                                Click="ShowWarningMessageButton_OnClick" />
                                        <Button Margin="0,0,8,8"
                                                Content="Notification"
                                                Click="ShowNotificationButton_OnClick" />
                                        <Button Margin="0,0,0,8"
                                                Content="Modal"
                                                Click="ShowModalButton_OnClick" />
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>






