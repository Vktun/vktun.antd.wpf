<UserControl x:Class="Vktun.Antd.Wpf.Sample.Pages.OtherPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:antd="clr-namespace:Vktun.Antd.Wpf;assembly=Vktun.Antd.Wpf"
             xmlns:controls="clr-namespace:Vktun.Antd.Wpf.Sample.Controls"
             xmlns:snippets="clr-namespace:Vktun.Antd.Wpf.Sample.Snippets">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="4,0,4,12">
            <TextBlock Style="{StaticResource Catalog.PageTitleTextStyle}"
                       Text="其他" />
            <TextBlock Style="{StaticResource Catalog.PageDescriptionTextStyle}"
                       Text="这里集中说明 ConfigProvider 在 WPF 中的映射方式，以及主题资源如何在运行时切换。" />

            <controls:ComponentDemo Title="ConfigProvider -> AntdThemeResources + AntdThemeManager"
                                    Description="WPF 版本通过资源字典和主题管理器承担 ConfigProvider 的职责，目录页顶部的主题切换就是实际运行示例。"
                                    XamlCode="{x:Static snippets:OtherSnippets.ConfigProvider}"
                                    CSharpCode="{x:Static snippets:OtherSnippets.ThemeManager}"
                                    PreviewMinHeight="220">
                <controls:ComponentDemo.PreviewContent>
                    <antd:Card Header="当前推荐用法">
                        <StackPanel>
                            <TextBlock Text="1. 在 App.xaml 合并 antd:AntdThemeResources。" />
                            <TextBlock Margin="0,10,0,0"
                                       Text="2. 在运行时通过 AntdThemeManager.Current.Apply(...) 切换 Light / Dark 和 SeedToken。" />
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="sample 顶部主题选择器会同步更新窗口氛围、色板、卡片和弹层资源。" />
                            <WrapPanel Margin="0,16,0,0">
                                <antd:Tag Margin="0,0,8,8" Color="Blue">AntdThemeResources</antd:Tag>
                                <antd:Tag Margin="0,0,8,8" Color="Success">AntdThemeManager</antd:Tag>
                                <antd:Tag Margin="0,0,0,8" Color="Orange">SeedToken</antd:Tag>
                            </WrapPanel>
                        </StackPanel>
                    </antd:Card>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>
        </StackPanel>
    </ScrollViewer>
</UserControl>
