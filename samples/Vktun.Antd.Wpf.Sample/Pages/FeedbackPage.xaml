<UserControl x:Class="Vktun.Antd.Wpf.Sample.Pages.FeedbackPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:antd="clr-namespace:Vktun.Antd.Wpf;assembly=Vktun.Antd.Wpf"
             xmlns:controls="clr-namespace:Vktun.Antd.Wpf.Sample.Controls"
             xmlns:snippets="clr-namespace:Vktun.Antd.Wpf.Sample.Snippets">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="4,0,4,12">
            <TextBlock Style="{StaticResource Catalog.PageTitleTextStyle}"
                       Text="反馈" />
            <TextBlock Style="{StaticResource Catalog.PageDescriptionTextStyle}"
                       Text="反馈类组件除了声明式控件，也包含 Message、Modal、Notification 这样的服务调用映射。" />

            <controls:ComponentDemo Title="Alert"
                                    Description="支持信息、成功、警告和错误状态，并可带图标。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Alert}">
                <controls:ComponentDemo.PreviewContent>
                    <StackPanel>
                        <antd:Alert Margin="0,0,0,12"
                                    Type="Success"
                                    Message="构建完成"
                                    Description="所有页面和服务示例均已加载。"
                                    ShowIcon="True" />
                        <antd:Alert Type="Warning"
                                    Message="请关注兼容层"
                                    Description="旧 assist 类仍保留，但内部使用点已开始收敛。"
                                    ShowIcon="True" />
                    </StackPanel>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Drawer"
                                    Description="Drawer 适合承载补充信息和轻量表单，示例通过按钮控制打开状态。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Drawer}"
                                    PreviewMinHeight="260">
                <controls:ComponentDemo.PreviewContent>
                    <Grid Height="240">
                        <Border Background="{DynamicResource Antd.Brush.BgContainer}"
                                BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                BorderThickness="1"
                                CornerRadius="16" />
                        <StackPanel Margin="18">
                            <TextBlock FontWeight="SemiBold" Text="主内容区" />
                            <TextBlock Margin="0,8,0,16"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="点击右侧按钮打开抽屉，查看补充信息。"
                                       TextWrapping="Wrap" />
                            <antd:Button Width="120"
                                         Type="Primary"
                                         Click="OpenDrawerButton_OnClick"
                                         Content="打开 Drawer" />
                        </StackPanel>

                        <antd:Drawer Title="发布说明"
                                     Width="320"
                                     Placement="Right">
                            <StackPanel Margin="0,8,0,0">
                                <TextBlock Text="Drawer 适合承载附加配置和上下文说明。"
                                           TextWrapping="Wrap" />
                                <antd:Button Margin="0,16,0,0"
                                             Width="96"
                                             Click="CloseDrawerButton_OnClick"
                                             Content="关闭" />
                            </StackPanel>
                        </antd:Drawer>
                    </Grid>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Popconfirm"
                                    Description="危险操作前的二次确认，适合删除、回滚等动作。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Popconfirm}">
                <controls:ComponentDemo.PreviewContent>
                    <antd:Popconfirm Title="确认删除这条记录？"
                                     OkText="删除"
                                     CancelText="取消"
                                     Confirm="Popconfirm_OnConfirm"
                                     Cancel="Popconfirm_OnCancel">
                        <antd:Button Content="Delete" Status="Error" />
                    </antd:Popconfirm>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Progress"
                                    Description="用于表达任务进度和完成状态。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Progress}">
                <controls:ComponentDemo.PreviewContent>
                    <StackPanel Width="280">
                        <antd:Progress Percent="68" />
                        <antd:Progress Margin="0,16,0,0"
                                       Percent="100"
                                       Status="Success" />
                    </StackPanel>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Result"
                                    Description="适合在提交成功、失败或空权限状态下呈现结果页。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Result}">
                <controls:ComponentDemo.PreviewContent>
                    <antd:Result Status="Success"
                                 Title="目录页已重构"
                                 SubTitle="组件分类、代码片段和主题切换已经打通。" />
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Skeleton / Spin"
                                    Description="Skeleton 负责骨架屏，Spin 负责局部 loading。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.SkeletonSpin}"
                                    PreviewMinHeight="240">
                <controls:ComponentDemo.PreviewContent>
                    <StackPanel>
                        <antd:Skeleton Avatar="True"
                                       ParagraphRows="3" />
                        <antd:Spin Margin="0,20,0,0"
                                   Tip="正在加载目录数据...">
                            <antd:Spin.Content>
                                <Border Padding="20"
                                        Background="{DynamicResource Antd.Brush.BgContainer}"
                                        BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <TextBlock Text="被 Spin 包裹的内容区。" />
                                </Border>
                            </antd:Spin.Content>
                        </antd:Spin>
                    </StackPanel>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Message / Modal / Notification"
                                    Description="这三个组件在 WPF 中更适合作为服务调用，而不是单纯的声明式控件。"
                                    CSharpCode="{x:Static snippets:FeedbackSnippets.ServiceFeedback}">
                <controls:ComponentDemo.PreviewContent>
                    <WrapPanel>
                        <antd:Button Margin="0,0,12,12"
                                     Type="Primary"
                                     Click="ShowMessageButton_OnClick"
                                     Content="Show Message" />
                        <antd:Button Margin="0,0,12,12"
                                     Click="ShowNotificationButton_OnClick"
                                     Content="Show Notification" />
                        <antd:Button Margin="0,0,12,12"
                                     Click="ShowModalButton_OnClick"
                                     Content="Show Modal" />
                    </WrapPanel>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>

            <controls:ComponentDemo Title="Watermark"
                                    Description="本轮新增 Watermark，使用平铺文本画刷为内容添加水印层。"
                                    XamlCode="{x:Static snippets:FeedbackSnippets.Watermark}"
                                    PreviewMinHeight="220">
                <controls:ComponentDemo.PreviewContent>
                    <antd:Watermark Text="Ant Design WPF"
                                    FontSize="18"
                                    GapX="180"
                                    GapY="120">
                        <antd:Card Header="受保护内容">
                            <TextBlock Text="水印会平铺到包裹内容之上。" />
                        </antd:Card>
                    </antd:Watermark>
                </controls:ComponentDemo.PreviewContent>
            </controls:ComponentDemo>
        </StackPanel>
    </ScrollViewer>
</UserControl>
