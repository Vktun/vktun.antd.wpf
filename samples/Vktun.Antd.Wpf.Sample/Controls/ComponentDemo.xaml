<UserControl x:Class="Vktun.Antd.Wpf.Sample.Controls.ComponentDemo"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource Catalog.CardSurfaceStyle}">
        <StackPanel>
            <TextBlock FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource Antd.Brush.Text}"
                       Text="{Binding Title, ElementName=Root}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                       Text="{Binding Description, ElementName=Root}"
                       TextWrapping="Wrap" />

            <Border Margin="0,16,0,0"
                    MinHeight="{Binding PreviewMinHeight, ElementName=Root}"
                    Style="{StaticResource Catalog.SubtleSurfaceStyle}">
                <ContentPresenter Content="{Binding PreviewContent, ElementName=Root}" />
            </Border>

            <Border Margin="0,16,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding XamlCode, ElementName=Root}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                               Text="XAML" />
                    <TextBox Style="{StaticResource Catalog.CodeTextBoxStyle}"
                             Text="{Binding XamlCode, ElementName=Root}" />
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CSharpCode, ElementName=Root}" Value="">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Margin="0,0,0,8"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                               Text="C#" />
                    <TextBox Style="{StaticResource Catalog.CodeTextBoxStyle}"
                             Text="{Binding CSharpCode, ElementName=Root}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
