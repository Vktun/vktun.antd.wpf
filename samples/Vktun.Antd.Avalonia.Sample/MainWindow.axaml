<Window x:Class="Vktun.Antd.Avalonia.Sample.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="960"
        Height="640"
        Title="Vktun.Antd Avalonia Sample"
        Background="{DynamicResource Antd.Brush.BgLayout}">
  <Grid RowDefinitions="Auto,*" Margin="24" RowSpacing="20">
    <StackPanel Spacing="8">
      <TextBlock Text="Vktun.Antd Avalonia"
                 FontSize="28"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource Antd.Brush.Text}" />
      <TextBlock Text="Shared token resources are loaded through AntdThemeResources."
                 Foreground="{DynamicResource Antd.Brush.TextSecondary}" />
    </StackPanel>

    <Border Grid.Row="1"
            Background="{DynamicResource Antd.Brush.BgContainer}"
            BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Antd.BorderRadius.Lg}"
            Padding="24">
      <StackPanel Spacing="16">
        <TextBlock Text="Light theme baseline"
                   FontSize="{DynamicResource Antd.FontSize.Large}"
                   Foreground="{DynamicResource Antd.Brush.Text}" />
        <Button Content="Primary action"
                HorizontalAlignment="Left"
                Background="{DynamicResource Antd.Brush.Primary}"
                Foreground="{DynamicResource Antd.Brush.White}" />
        <TextBlock Text="The first Avalonia surface is intentionally small; controls can be ported component by component on top of this theme layer."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource Antd.Brush.TextSecondary}" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
