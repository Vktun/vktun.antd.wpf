<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">
    <Style x:Key="Antd.CardSurface" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Effect" Value="{DynamicResource {x:Static local:AntdResourceKeys.ShadowCard}}" />
    </Style>

    <Style TargetType="{x:Type local:Card}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Card}">
                    <Border Style="{StaticResource Antd.CardSurface}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid Margin="20,18,20,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter ContentSource="Header" VerticalAlignment="Center" RecognizesAccessKey="True" />
                                <ContentPresenter Grid.Column="1" ContentSource="Extra" VerticalAlignment="Center" />
                            </Grid>
                            <ContentPresenter Grid.Row="1" Margin="20,0,20,20" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Tag}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tag}">
                    <Border x:Name="Root"
                            Padding="10,4"
                            CornerRadius="999"
                            Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushTagDefaultBackground}}">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="local:StatusAssist.Status" Value="Success">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="local:StatusAssist.Status" Value="Warning">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                        <Trigger Property="local:StatusAssist.Status" Value="Error">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                            <Setter Property="Foreground" Value="White" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Badge}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Badge}">
                    <Grid>
                        <ContentPresenter />
                        <Border x:Name="BadgeElement"
                                MinWidth="20"
                                Height="20"
                                Padding="6,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-8,-8,0"
                                CornerRadius="10"
                                Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBadgeBackground}}">
                            <TextBlock x:Name="BadgeText"
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Text="{TemplateBinding Count}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Count" Value="{x:Null}">
                            <Setter TargetName="BadgeElement" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Dot" Value="True">
                            <Setter TargetName="BadgeElement" Property="Width" Value="10" />
                            <Setter TargetName="BadgeElement" Property="Height" Value="10" />
                            <Setter TargetName="BadgeElement" Property="MinWidth" Value="10" />
                            <Setter TargetName="BadgeElement" Property="Padding" Value="0" />
                            <Setter TargetName="BadgeText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
