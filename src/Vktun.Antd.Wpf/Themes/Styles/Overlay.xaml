<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:core="clr-namespace:Vktun.Antd;assembly=Vktun.Antd.Core">

    <!-- Drawer Styles -->
    <Style TargetType="{x:Type local:Drawer}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Drawer}">
                    <Grid>
                        <!-- Mask Overlay -->
                        <Border x:Name="Mask"
                                Background="#000000"
                                Opacity="0.45"
                                Visibility="Collapsed"
                                Cursor="Arrow">
                        </Border>
                        <!-- Drawer Panel -->
                        <Border x:Name="DrawerPanel"
                                Background="{TemplateBinding Background}"
                                Visibility="Collapsed"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch"
                                Width="{TemplateBinding Width}"
                                Effect="{DynamicResource Antd.Shadow.Popup}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <!-- Header -->
                                <Border x:Name="Header"
                                        Grid.Row="0"
                                        Background="{DynamicResource Antd.Brush.BgContainer}"
                                        BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter x:Name="TitlePresenter"
                                                          Grid.Column="0"
                                                          Content="{TemplateBinding Title}" />
                                        <ContentPresenter x:Name="ExtraPresenter"
                                                          Grid.Column="1"
                                                          Margin="16,0"
                                                          Content="{TemplateBinding Extra}" />
                                        <Button x:Name="CloseButton"
                                                Grid.Column="2"
                                                Width="32"
                                                Height="32"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                Visibility="Collapsed">
                                            <Path Width="12"
                                                  Height="12"
                                                  StrokeThickness="1.5"
                                                  Stroke="{DynamicResource Antd.Brush.TextTertiary}"
                                                  Data="M 2 2 L 10 10 M 10 2 L 2 10" />
                                        </Button>
                                    </Grid>
                                </Border>
                                <!-- Content -->
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Grid.Row="1" />
                                <!-- Footer -->
                                <Border x:Name="Footer"
                                        Grid.Row="2"
                                        Background="{DynamicResource Antd.Brush.BgContainer}"
                                        BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                        BorderThickness="0,1,0,0"
                                        Padding="16,14"
                                        Visibility="Collapsed">
                                    <ContentPresenter Content="{TemplateBinding Footer}" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsOpen" Value="True">
                            <Setter TargetName="Mask" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DrawerPanel" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowMask" Value="False">
                            <Setter TargetName="Mask" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Placement" Value="Left">
                            <Setter TargetName="DrawerPanel" Property="HorizontalAlignment" Value="Left" />
                        </Trigger>
                        <Trigger Property="Placement" Value="Top">
                            <Setter TargetName="DrawerPanel" Property="HorizontalAlignment" Value="Stretch" />
                            <Setter TargetName="DrawerPanel" Property="VerticalAlignment" Value="Top" />
                            <Setter TargetName="DrawerPanel" Property="Width" Value="Auto" />
                            <Setter TargetName="DrawerPanel" Property="Height" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Height}" />
                        </Trigger>
                        <Trigger Property="Placement" Value="Bottom">
                            <Setter TargetName="DrawerPanel" Property="HorizontalAlignment" Value="Stretch" />
                            <Setter TargetName="DrawerPanel" Property="VerticalAlignment" Value="Bottom" />
                            <Setter TargetName="DrawerPanel" Property="Width" Value="Auto" />
                            <Setter TargetName="DrawerPanel" Property="Height" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Height}" />
                        </Trigger>
                        <Trigger Property="Closable" Value="True">
                            <Setter TargetName="CloseButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="Header" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Footer" Value="{x:Null}">
                            <Setter TargetName="Footer" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Extra" Value="{x:Null}">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Step Styles -->
    <Style TargetType="{x:Type local:Step}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Step}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Icon Container -->
                        <Border x:Name="IconContainer"
                                Grid.Column="0"
                                Width="32"
                                Height="32"
                                Background="{DynamicResource Antd.Brush.BgContainer}"
                                BorderBrush="{DynamicResource Antd.Brush.Border}"
                                BorderThickness="1"
                                CornerRadius="16">
                            <Grid>
                                <!-- Custom Icon -->
                                <ContentPresenter x:Name="CustomIcon"
                                                  Content="{TemplateBinding Icon}"
                                                  Visibility="Collapsed" />
                                <!-- Number/Status Icon -->
                                <TextBlock x:Name="NumberIcon"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           FontWeight="Medium"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Index}" />
                                <!-- Finish Check -->
                                <Path x:Name="FinishIcon"
                                      Width="14"
                                      Height="14"
                                      StrokeThickness="2"
                                      Stroke="{DynamicResource Antd.Brush.Primary}"
                                      Data="M 2 8 L 6 12 L 14 4"
                                      Visibility="Collapsed" />
                                <!-- Error X -->
                                <Path x:Name="ErrorIcon"
                                      Width="14"
                                      Height="14"
                                      StrokeThickness="2"
                                      Stroke="{DynamicResource Antd.Brush.Error}"
                                      Data="M 4 4 L 12 12 M 12 4 L 4 12"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <!-- Content -->
                        <StackPanel x:Name="ContentPanel"
                                    Grid.Column="1"
                                    Margin="8,0"
                                    VerticalAlignment="Center">
                            <ContentPresenter x:Name="TitlePresenter"
                                              Content="{TemplateBinding Title}" />
                            <ContentPresenter x:Name="SubTitlePresenter"
                                              Margin="0,4,0,0"
                                              Content="{TemplateBinding SubTitle}" />
                            <ContentPresenter x:Name="DescriptionPresenter"
                                              Margin="0,4,0,0"
                                              Content="{TemplateBinding Description}"
                                              Visibility="Collapsed" />
                        </StackPanel>
                        <!-- Tail Line -->
                        <Border x:Name="TailLine"
                                Grid.Column="2"
                                Width="Auto"
                                Height="1"
                                Background="{DynamicResource Antd.Brush.BorderSecondary}"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="CustomIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Status" Value="Wait">
                            <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
                            <Setter TargetName="IconContainer" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Border}" />
                            <Setter TargetName="NumberIcon" Property="Foreground" Value="{DynamicResource Antd.Brush.TextTertiary}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Process">
                            <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter TargetName="IconContainer" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter TargetName="NumberIcon" Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Finish">
                            <Setter TargetName="NumberIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FinishIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryBg}" />
                            <Setter TargetName="IconContainer" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter TargetName="TailLine" Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="NumberIcon" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ErrorIcon" Property="Visibility" Value="Visible" />
                            <Setter TargetName="IconContainer" Property="Background" Value="{DynamicResource Antd.Brush.ErrorBg}" />
                            <Setter TargetName="IconContainer" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                        <Trigger Property="IsLast" Value="False">
                            <Setter TargetName="TailLine" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Steps}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Steps}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <Grid Margin="0,0,24,0">
                        <local:Step />
                    </Grid>
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Dropdown Styles -->
    <Style TargetType="{x:Type local:DropdownItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DropdownItem}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="IconPresenter"
                                              Grid.Column="0"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="HeaderPresenter"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDivider" Value="True">
                            <Setter TargetName="Root" Property="Height" Value="1" />
                            <Setter TargetName="Root" Property="Padding" Value="0" />
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BorderSecondary}" />
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="Danger" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Danger" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.ErrorBg}" />
                        </MultiTrigger>
                        <Trigger Property="IsDisabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:DropdownMenu}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.BorderSecondary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="4,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DropdownMenu}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="8"
                            Effect="{DynamicResource Antd.Shadow.Popup}">
                        <StackPanel>
                            <ItemsPresenter />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Dropdown}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Dropdown}">
                    <Grid>
                        <ContentPresenter x:Name="TriggerContent"
                                          ContentSource="Content" />
                        <Popup x:Name="PART_Popup"
                               Placement="{TemplateBinding Placement}"
                               IsOpen="{TemplateBinding IsOpen}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <ContentPresenter Content="{TemplateBinding Menu}" />
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Disabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:DropdownButton}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="12,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DropdownButton}">
                    <Grid>
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="8">
                            <StackPanel Orientation="Horizontal">
                                <ContentPresenter x:Name="IconPresenter"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Icon}" />
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Content" />
                                <Path x:Name="ArrowIcon"
                                      Margin="8,0,0,0"
                                      Width="10"
                                      Height="10"
                                      StrokeThickness="1.5"
                                      Stroke="{TemplateBinding Foreground}"
                                      Data="M 2 2 L 8 6 L 2 10" />
                            </StackPanel>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               Placement="{TemplateBinding Placement}"
                               IsOpen="{TemplateBinding IsOpen}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <ContentPresenter Content="{TemplateBinding Menu}" />
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="HeaderPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Type" Value="Primary">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="Disabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Popconfirm Styles -->
    <Style TargetType="{x:Type local:Popconfirm}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Popconfirm}">
                    <Grid>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Cursor="Hand" />
                        <Popup x:Name="PART_Popup"
                               PlacementTarget="{Binding ElementName=ContentPresenter}"
                               Placement="{TemplateBinding Placement}"
                               IsOpen="{TemplateBinding IsOpen}"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade">
                            <Border Background="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgContainer}}"
                                    BorderBrush="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorderSecondary}}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    MaxWidth="320"
                                    Effect="{DynamicResource {x:Static core:AntdResourceKeys.ShadowPopup}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <!-- Warning Icon -->
                                        <Path x:Name="WarningIcon"
                                              Width="14"
                                              Height="14"
                                              Margin="0,2,8,0"
                                              Data="M 12 2 L 22 20 L 2 20 Z M 12 8 L 12 13 M 12 16 L 12 16.01"
                                              Stroke="#FAAD14"
                                              StrokeThickness="2"
                                              Stretch="Uniform"
                                              Visibility="Collapsed" />
                                        <TextBlock Text="{TemplateBinding Title}"
                                                   FontSize="14"
                                                   Foreground="{DynamicResource {x:Static core:AntdResourceKeys.BrushText}}"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <local:Button x:Name="PART_CancelButton"
                                                      Content="{TemplateBinding CancelText}"
                                                      Type="Default"
                                                      Margin="0,0,8,0" />
                                        <local:Button x:Name="PART_ConfirmButton"
                                                      Content="{TemplateBinding OkText}"
                                                      Type="{TemplateBinding OkType}" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowIcon" Value="True">
                            <Setter TargetName="WarningIcon" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>