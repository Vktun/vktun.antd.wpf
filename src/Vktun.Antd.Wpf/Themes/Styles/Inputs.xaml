<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:core="clr-namespace:Vktun.Antd;assembly=Vktun.Antd.Core">

    <!-- Input Base Style -->
    <Style x:Key="Antd.InputBaseStyle" TargetType="Control">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightMiddle}}" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <!-- Input (TextBox) Style -->
    <Style TargetType="{x:Type local:Input}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Input}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static core:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="PrefixPresenter"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Prefix}" />
                            <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" />
                            <ContentPresenter x:Name="SuffixPresenter"
                                              Grid.Column="2"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Suffix}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Prefix/Suffix visibility -->
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Focus and hover states -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                        <!-- Status triggers -->
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <!-- Variant triggers -->
                        <Trigger Property="Variant" Value="Filled">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillTertiary}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Borderless">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordInput Style -->
    <Style TargetType="{x:Type local:PasswordInput}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PasswordInput}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static core:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="PrefixPresenter"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Prefix}" />
                            <PasswordBox x:Name="PART_PasswordHost"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0" />
                            <ContentPresenter x:Name="SuffixPresenter"
                                              Grid.Column="2"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Suffix}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox Style (HandyControl-inspired implementation) -->
    <Style TargetType="{x:Type local:ComboBox}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ComboBox}">
                    <Grid SnapsToDevicePixels="True">
                        <!-- Main border and content area -->
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource {x:Static core:AntdResourceKeys.BorderRadiusMiddle}}">
                            <Grid x:Name="ContentGrid" Margin="12,0,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <!-- Prefix content -->
                                <ContentPresenter x:Name="PrefixPresenter"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Prefix}" />
                                <!-- Selection box content -->
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="1"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                <!-- Suffix and arrow combined in last column -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <ContentPresenter x:Name="SuffixPresenter"
                                                      Margin="0,0,8,0"
                                                      VerticalAlignment="Center"
                                                      Content="{TemplateBinding Suffix}" />
                                    <!-- Arrow indicator using ToggleBlock pattern -->
                                    <Grid Width="14" Height="14" Margin="0,0,2,0">
                                        <Path x:Name="PART_Arrow"
                                              Data="M 0 0 L 5 6 L 10 0"
                                              StrokeThickness="1.5"
                                              Stroke="{DynamicResource {x:Static core:AntdResourceKeys.BrushTextSecondary}}"
                                              RenderTransformOrigin="0.5,0.5"
                                              Stretch="Uniform">
                                            <Path.RenderTransform>
                                                <RotateTransform Angle="0" />
                                            </Path.RenderTransform>
                                        </Path>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Click handler covering entire control (HandyControl pattern) -->
                        <local:ToggleBlock x:Name="PART_DropDownToggle"
                                           Background="Transparent"
                                           VerticalContentAlignment="Stretch"
                                           HorizontalContentAlignment="Stretch"
                                           IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        
                        <!-- Popup dropdown -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=Border}"
                               VerticalOffset="6">
                            <Decorator Margin="0,6,0,8">
                                <Border x:Name="PART_PopupBorder"
                                        MinWidth="{Binding ActualWidth, ElementName=Border}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgElevated}}"
                                        BorderBrush="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorderSecondary}}"
                                        BorderThickness="1"
                                        CornerRadius="{DynamicResource {x:Static core:AntdResourceKeys.BorderRadiusMiddle}}"
                                        Effect="{DynamicResource {x:Static core:AntdResourceKeys.ShadowPopup}}">
                                    <ScrollViewer MaxHeight="240"
                                                  CanContentScroll="True"
                                                  Margin="2">
                                        <ItemsPresenter x:Name="ItemsPresenter"
                                                        KeyboardNavigation.DirectionalNavigation="Contained"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </ScrollViewer>
                                </Border>
                            </Decorator>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Prefix/Suffix visibility -->
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        
                        <!-- Dropdown arrow rotation and color (HandyControl pattern) -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="PART_Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="PART_Arrow" Property="Stroke" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        
                        <!-- Empty state handling (HandyControl pattern) -->
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="PART_PopupBorder" Property="Height" Value="95" />
                        </Trigger>
                        
                        <!-- Variant triggers -->
                        <Trigger Property="Variant" Value="Filled">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillTertiary}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Borderless">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="ContentGrid" Property="Margin" Value="6,0,6,0" />
                        </Trigger>
                        
                        <!-- Focus and hover states by variant -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Outlined" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsDropDownOpen" Value="False" />
                                <Condition Property="Variant" Value="Outlined" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimaryHover}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Filled" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgContainer}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsDropDownOpen" Value="False" />
                                <Condition Property="Variant" Value="Filled" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillSecondary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Borderless" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillSecondary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsDropDownOpen" Value="False" />
                                <Condition Property="Variant" Value="Borderless" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillQuaternary}}" />
                        </MultiTrigger>
                        
                        <!-- Status triggers -->
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static core:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static core:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        
                        <!-- Disabled state -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem Style -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushText}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Root"
                            Margin="4"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillSecondary}}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgSpotlight}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
