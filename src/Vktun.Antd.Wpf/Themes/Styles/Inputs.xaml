<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">

    <!-- Input Base Style -->
    <Style x:Key="Antd.InputBaseStyle" TargetType="Control">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightMiddle}}" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <!-- Input (TextBox) Style -->
    <Style TargetType="{x:Type local:Input}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Input}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="PrefixPresenter"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Prefix}" />
                            <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center" />
                            <ContentPresenter x:Name="SuffixPresenter"
                                              Grid.Column="2"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Suffix}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Prefix/Suffix visibility -->
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Focus and hover states -->
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                        <!-- Status triggers -->
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <!-- Variant triggers -->
                        <Trigger Property="Variant" Value="Filled">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillTertiary}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Borderless">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordInput Style -->
    <Style TargetType="{x:Type local:PasswordInput}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:PasswordInput}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="PrefixPresenter"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Prefix}" />
                            <PasswordBox x:Name="PART_PasswordHost"
                                         Grid.Column="1"
                                         VerticalAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         PasswordChar="*"
                                         Password="{Binding Password, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" />
                            <ContentPresenter x:Name="SuffixPresenter"
                                              Grid.Column="2"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Suffix}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBox Style -->
    <Style TargetType="{x:Type local:ComboBox}" BasedOn="{StaticResource Antd.InputBaseStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ComboBox}">
                    <Grid SnapsToDevicePixels="True">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                            <Grid x:Name="ContentGrid" Margin="12,0,12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="PrefixPresenter"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Prefix}" />
                                <ContentPresenter Grid.Column="1"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" />
                                <ContentPresenter x:Name="SuffixPresenter"
                                                  Grid.Column="2"
                                                  Margin="0,0,8,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Suffix}" />
                                <Path x:Name="PART_Arrow"
                                      Grid.Column="3"
                                      Width="10"
                                      Height="6"
                                      VerticalAlignment="Center"
                                      Data="M 0 0 L 5 6 L 10 0"
                                      StrokeThickness="1.5"
                                      Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Border>
                        <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                            <Border x:Name="PopupBorder"
                                    Margin="0,6,0,0"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}"
                                    BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Effect="{DynamicResource {x:Static local:AntdResourceKeys.ShadowPopup}}">
                                <ScrollViewer MaxHeight="240"
                                              CanContentScroll="True">
                                    <StackPanel IsItemsHost="True" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Prefix/Suffix visibility -->
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <!-- Dropdown arrow rotation -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="PART_Arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="180" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <!-- Variant triggers -->
                        <Trigger Property="Variant" Value="Filled">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillTertiary}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                        </Trigger>
                        <Trigger Property="Variant" Value="Borderless">
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
                            <Setter TargetName="ContentGrid" Property="Margin" Value="6,0,6,0" />
                        </Trigger>
                        <!-- Focus and hover states by variant -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Outlined" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="Variant" Value="Outlined" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Filled" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="Variant" Value="Filled" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillSecondary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsKeyboardFocusWithin" Value="True" />
                                <Condition Property="Variant" Value="Borderless" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillSecondary}}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="Variant" Value="Borderless" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Border" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillQuaternary}}" />
                        </MultiTrigger>
                        <!-- Status triggers -->
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem Style -->
    <Style TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Root"
                            Margin="4"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillSecondary}}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgSpotlight}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>