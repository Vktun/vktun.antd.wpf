<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Style TargetType="{x:Type local:FloatButton}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FloatButton}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            Effect="{DynamicResource Antd.Shadow.Popup}">
                        <StackPanel Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="MainContentPresenter"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Center"
                                              ContentSource="Content" />
                            <ContentPresenter x:Name="DescriptionPresenter"
                                              Margin="0,2,0,0"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Description}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Shape" Value="Circle">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="999" />
                        </Trigger>
                        <Trigger Property="Shape" Value="Square">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="14" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MainContentPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="MainContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="DescriptionPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.ActionButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.PageButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Pagination}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Pagination}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                local:SpaceAssist.Gap="18">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    local:SpaceAssist.Gap="8">
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PreviousPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 7 1 L 1 6 L 7 11" />
                            </Button>
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,4,0">
                                            <TextBlock x:Name="EllipsisText"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"
                                                       Foreground="{DynamicResource Antd.Brush.TextTertiary}"
                                                       Text="{Binding Text}" />
                                            <Button x:Name="PageButton"
                                                    Style="{StaticResource Antd.Pagination.PageButtonStyle}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Pagination}}, Path=SelectPageCommand}"
                                                    CommandParameter="{Binding PageNumber}"
                                                    Content="{Binding Text}" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                <Setter TargetName="EllipsisText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PageButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=NextPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 1 1 L 7 6 L 1 11" />
                            </Button>
                        </StackPanel>

                        <ComboBox x:Name="PageSizeSelector"
                                  Width="110"
                                  MinHeight="36"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSizeOptions}"
                                  SelectedItem="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSize, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel x:Name="QuickJumperPanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    local:SpaceAssist.Gap="8">
                            <TextBlock VerticalAlignment="Center" Text="跳至" />
                            <TextBox x:Name="PART_QuickJumperTextBox"
                                     Width="52"
                                     Padding="0"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=QuickJumpText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock VerticalAlignment="Center" Text="页" />
                        </StackPanel>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowSizeChanger" Value="False">
                            <Setter TargetName="PageSizeSelector" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowQuickJumper" Value="False">
                            <Setter TargetName="QuickJumperPanel" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Styles -->
    <Style TargetType="{x:Type local:MenuItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:MenuItem}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="IconPresenter"
                                              Grid.Column="0"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="HeaderPresenter"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                            <Path x:Name="ExpandArrow"
                                  Grid.Column="2"
                                  Width="10"
                                  Height="10"
                                  StrokeThickness="1.5"
                                  Stroke="{TemplateBinding Foreground}"
                                  Data="M 2 2 L 8 6 L 2 10"
                                  Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasSubmenu" Value="True">
                            <Setter TargetName="ExpandArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Antd.Brush.PrimaryBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsDisabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Submenu}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Submenu}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="IconPresenter"
                                              Grid.Column="0"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="HeaderPresenter"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                            <Path x:Name="ExpandArrow"
                                  Grid.Column="2"
                                  Width="10"
                                  Height="10"
                                  StrokeThickness="1.5"
                                  Stroke="{TemplateBinding Foreground}"
                                  Data="M 2 2 L 8 6 L 2 10" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandArrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsDisabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Menu}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Menu}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="8">
                        <StackPanel Orientation="Vertical">
                            <ItemsPresenter />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Theme" Value="Dark">
                            <Setter TargetName="RootBorder" Property="Background" Value="#1F1F1F" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
                        </Trigger>
                        <Trigger Property="Mode" Value="Horizontal">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="0" />
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tabs Styles -->
    <Style TargetType="{x:Type local:TabPane}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabPane}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="16">
                        <ContentPresenter ContentSource="Content" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.TabButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="Tag" Value="Selected">
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Tabs}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgLayout}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tabs}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Tab Bar -->
                        <Border x:Name="TabBar"
                                Grid.Row="0"
                                Background="{DynamicResource Antd.Brush.BgContainer}"
                                BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                BorderThickness="0,0,0,1"
                                Padding="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel x:Name="TabsList"
                                            Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="16,0">
                                    <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button x:Name="TabButton"
                                                        Style="{StaticResource Antd.TabButtonStyle}"
                                                        Content="{Binding Header}"
                                                        Tag="Normal">
                                                    <Button.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter TargetName="TabButton" Property="Tag" Value="Selected" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                                <ContentPresenter x:Name="ExtraPresenter"
                                                  Grid.Column="2"
                                                  Margin="16,0"
                                                  Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Extra}" />
                            </Grid>
                        </Border>
                        <!-- Tab Content -->
                        <Border x:Name="TabContent"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedItem}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Type" Value="Card">
                            <Setter TargetName="TabBar" Property="BorderThickness" Value="0" />
                        </Trigger>
                        <Trigger Property="Position" Value="Bottom">
                            <Setter TargetName="TabBar" Property="Grid.Row" Value="1" />
                            <Setter TargetName="TabContent" Property="Grid.Row" Value="0" />
                        </Trigger>
                        <Trigger Property="Extra" Value="{x:Null}">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>





