<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Style TargetType="{x:Type local:FloatButton}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FloatButton}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            Effect="{DynamicResource Antd.Shadow.Popup}">
                        <StackPanel Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="MainContentPresenter"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Center"
                                              ContentSource="Content" />
                            <ContentPresenter x:Name="DescriptionPresenter"
                                              Margin="0,2,0,0"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Description}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Shape" Value="Circle">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="999" />
                        </Trigger>
                        <Trigger Property="Shape" Value="Square">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="14" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MainContentPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="MainContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="DescriptionPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.ActionButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.PageButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.SizeSelectorStyle"
           TargetType="{x:Type local:ComboBox}"
           BasedOn="{StaticResource {x:Type local:ComboBox}}">
        <Setter Property="Width" Value="124" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
    </Style>

    <Style x:Key="Antd.Pagination.QuickJumpInputStyle"
           TargetType="{x:Type local:Input}"
           BasedOn="{StaticResource {x:Type local:Input}}">
        <Setter Property="Width" Value="64" />
        <Setter Property="MinHeight" Value="36" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style TargetType="{x:Type local:Pagination}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Pagination}">
                    <local:Space Orientation="Horizontal"
                                 VerticalAlignment="Center"
                                 Gap="18">
                        <local:Space Orientation="Horizontal"
                                     VerticalAlignment="Center"
                                     Gap="8">
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PreviousPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 7 1 L 1 6 L 7 11" />
                            </Button>
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,4,0">
                                            <TextBlock x:Name="EllipsisText"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"
                                                       Foreground="{DynamicResource Antd.Brush.TextTertiary}"
                                                       Text="{Binding Text}" />
                                            <Button x:Name="PageButton"
                                                    Style="{StaticResource Antd.Pagination.PageButtonStyle}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Pagination}}, Path=SelectPageCommand}"
                                                    CommandParameter="{Binding PageNumber}"
                                                    Content="{Binding Text}" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                <Setter TargetName="EllipsisText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PageButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=NextPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 1 1 L 7 6 L 1 11" />
                            </Button>
                        </local:Space>

                        <local:ComboBox x:Name="PageSizeSelector"
                                        Style="{StaticResource Antd.Pagination.SizeSelectorStyle}"
                                        VerticalAlignment="Center"
                                        ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSizeOptions}"
                                        SelectedItem="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSize, Mode=TwoWay}">
                            <local:ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0} &#x6761;/&#x9875;}" />
                                </DataTemplate>
                            </local:ComboBox.ItemTemplate>
                        </local:ComboBox>

                        <local:Space x:Name="QuickJumperPanel"
                                     Orientation="Horizontal"
                                     VerticalAlignment="Center"
                                     Gap="8">
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="&#x8DF3;&#x81F3;" />
                            <local:Input x:Name="PART_QuickJumperTextBox"
                                         Style="{StaticResource Antd.Pagination.QuickJumpInputStyle}"
                                         MaxLength="9"
                                         Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=QuickJumpText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock VerticalAlignment="Center"
                                       Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                       Text="&#x9875;" />
                        </local:Space>
                    </local:Space>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowSizeChanger" Value="False">
                            <Setter TargetName="PageSizeSelector" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowQuickJumper" Value="False">
                            <Setter TargetName="QuickJumperPanel" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Menu Styles -->
    <Style TargetType="{x:Type local:MenuItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:MenuItem}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4"
                            Margin="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="IconPresenter"
                                              Grid.Column="0"
                                              Margin="0,0,10,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="HeaderPresenter"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              ContentSource="Header" />
                            <Path x:Name="ExpandArrow"
                                  Grid.Column="2"
                                  Width="10"
                                  Height="10"
                                  StrokeThickness="1.5"
                                  Stroke="{TemplateBinding Foreground}"
                                  Data="M 2 2 L 8 6 L 2 10"
                                  Visibility="Collapsed" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasSubmenu" Value="True">
                            <Setter TargetName="ExpandArrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Antd.Brush.PrimaryBg}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsDisabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Submenu}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Submenu}">
                    <StackPanel>
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4"
                                Margin="4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="IconPresenter"
                                                  Grid.Column="0"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Icon}" />
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  ContentSource="Header" />
                                <Path x:Name="ExpandArrow"
                                      Grid.Column="2"
                                      Width="10"
                                      Height="10"
                                      StrokeThickness="1.5"
                                      Stroke="{TemplateBinding Foreground}"
                                      Data="M 2 2 L 8 6 L 2 10"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>
                            </Grid>
                        </Border>
                        <Border x:Name="ChildrenBorder"
                                Margin="24,0,0,0"
                                Visibility="Collapsed">
                            <ItemsPresenter />
                        </Border>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsExpanded" Value="True">
                            <Setter TargetName="ExpandArrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ChildrenBorder" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsDisabled" Value="True">
                            <Setter Property="Opacity" Value="0.45" />
                            <Setter Property="Cursor" Value="None" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Menu}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Menu}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="8">
                        <ItemsPresenter />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Theme" Value="Dark">
                            <Setter TargetName="RootBorder" Property="Background" Value="#1F1F1F" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
                        </Trigger>
                        <Trigger Property="Mode" Value="Horizontal">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="0" />
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0,0,0,1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Mode" Value="Horizontal">
                <Setter Property="ItemsPanel">
                    <Setter.Value>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Tabs Styles -->
    <Style TargetType="{x:Type local:TabPane}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TabPane}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="16">
                        <ContentPresenter ContentSource="Content" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.TabButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.TextSecondary}" />
        <Setter Property="Padding" Value="14,10,14,10" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <Grid>
                                <Border x:Name="HoverLayer"
                                        Background="{DynamicResource Antd.Brush.FillSecondary}"
                                        CornerRadius="4"
                                        Opacity="0" />
                                <ContentPresenter x:Name="HeaderPresenter"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                    <ContentPresenter.RenderTransform>
                                        <TranslateTransform Y="0" />
                                    </ContentPresenter.RenderTransform>
                                </ContentPresenter>
                            </Grid>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="0:0:0.16" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsDisabled}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                            <Setter Property="Opacity" Value="0.5" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Tabs}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgLayout}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tabs}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <!-- Tab Bar -->
                        <Border x:Name="TabBar"
                                Grid.Row="0"
                                Background="{DynamicResource Antd.Brush.BgContainer}"
                                BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                BorderThickness="0,0,0,1"
                                Padding="0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid x:Name="TabsList"
                                      Grid.Column="0"
                                      Margin="16,0">
                                    <ItemsControl x:Name="PART_TabHeadersItemsControl"
                                                  ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Items}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button x:Name="TabButton"
                                                        Style="{StaticResource Antd.TabButtonStyle}"
                                                        Content="{Binding Header}"
                                                        Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Tabs}}, Path=SelectTabCommand}"
                                                        CommandParameter="{Binding}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Border x:Name="PART_ActiveIndicator"
                                            Width="0"
                                            Height="2"
                                            Margin="0,0,0,-1"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Bottom"
                                            Background="{DynamicResource Antd.Brush.Primary}"
                                            CornerRadius="1"
                                            Opacity="0.95">
                                        <Border.RenderTransform>
                                            <TranslateTransform X="0" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Grid>
                                <ContentPresenter x:Name="ExtraPresenter"
                                                  Grid.Column="2"
                                                  Margin="16,0"
                                                  Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Extra}" />
                            </Grid>
                        </Border>
                        <!-- Tab Content -->
                        <Border x:Name="PART_TabContent"
                                Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TranslateTransform Y="0" />
                            </Border.RenderTransform>
                            <ContentPresenter Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=SelectedItem}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Type" Value="Card">
                            <Setter TargetName="TabBar" Property="BorderThickness" Value="0" />
                        </Trigger>
                        <Trigger Property="Position" Value="Bottom">
                            <Setter TargetName="TabBar" Property="Grid.Row" Value="1" />
                            <Setter TargetName="PART_TabContent" Property="Grid.Row" Value="0" />
                        </Trigger>
                        <Trigger Property="Extra" Value="{x:Null}">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
