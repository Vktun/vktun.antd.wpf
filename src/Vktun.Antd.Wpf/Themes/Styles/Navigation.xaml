<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">
    <Style TargetType="{x:Type local:FloatButton}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.White}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="56" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:FloatButton}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="16"
                            Effect="{DynamicResource Antd.Shadow.Popup}">
                        <StackPanel Margin="{TemplateBinding Padding}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <ContentPresenter x:Name="IconPresenter"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Icon}" />
                            <ContentPresenter x:Name="MainContentPresenter"
                                              Margin="0,4,0,0"
                                              HorizontalAlignment="Center"
                                              ContentSource="Content" />
                            <ContentPresenter x:Name="DescriptionPresenter"
                                              Margin="0,2,0,0"
                                              HorizontalAlignment="Center"
                                              Content="{TemplateBinding Description}" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Shape" Value="Circle">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="999" />
                        </Trigger>
                        <Trigger Property="Shape" Value="Square">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="14" />
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MainContentPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="MainContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="DescriptionPresenter" Property="Margin" Value="0" />
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryHover}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.PrimaryActive}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.ActionButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Pagination.PageButtonStyle" TargetType="Button">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="MinWidth" Value="36" />
        <Setter Property="Height" Value="36" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.FillTertiary}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Primary}" />
                        </DataTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Pagination}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Pagination}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                local:SpaceAssist.Gap="18">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    local:SpaceAssist.Gap="8">
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PreviousPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 7 1 L 1 6 L 7 11" />
                            </Button>
                            <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,4,0">
                                            <TextBlock x:Name="EllipsisText"
                                                       VerticalAlignment="Center"
                                                       Visibility="Collapsed"
                                                       Foreground="{DynamicResource Antd.Brush.TextTertiary}"
                                                       Text="{Binding Text}" />
                                            <Button x:Name="PageButton"
                                                    Style="{StaticResource Antd.Pagination.PageButtonStyle}"
                                                    Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Pagination}}, Path=SelectPageCommand}"
                                                    CommandParameter="{Binding PageNumber}"
                                                    Content="{Binding Text}" />
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsEllipsis}" Value="True">
                                                <Setter TargetName="EllipsisText" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PageButton" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Button Style="{StaticResource Antd.Pagination.ActionButtonStyle}"
                                    Command="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=NextPageCommand}">
                                <Path Width="8"
                                      Height="12"
                                      StrokeThickness="1.5"
                                      Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                      Data="M 1 1 L 7 6 L 1 11" />
                            </Button>
                        </StackPanel>

                        <ComboBox x:Name="PageSizeSelector"
                                  Width="110"
                                  MinHeight="36"
                                  VerticalAlignment="Center"
                                  ItemsSource="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSizeOptions}"
                                  SelectedItem="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PageSize, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <StackPanel x:Name="QuickJumperPanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    local:SpaceAssist.Gap="8">
                            <TextBlock VerticalAlignment="Center" Text="跳至" />
                            <TextBox x:Name="PART_QuickJumperTextBox"
                                     Width="52"
                                     Padding="0"
                                     HorizontalContentAlignment="Center"
                                     Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=QuickJumpText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock VerticalAlignment="Center" Text="页" />
                        </StackPanel>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowSizeChanger" Value="False">
                            <Setter TargetName="PageSizeSelector" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ShowQuickJumper" Value="False">
                            <Setter TargetName="QuickJumperPanel" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>





