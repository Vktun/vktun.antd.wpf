<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">

    <!-- Alert Styles -->
    <Style TargetType="{x:Type local:Alert}">
        <Setter Property="Padding" Value="16,12" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Alert}">
                    <Border x:Name="RootBorder"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{DynamicResource Antd.BorderRadius.Md}"
                            BorderThickness="1"
                            Background="{DynamicResource Antd.Brush.InfoBackground}"
                            BorderBrush="{DynamicResource Antd.Brush.InfoBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Icon Area -->
                            <Viewbox x:Name="IconContainer"
                                     Width="16"
                                     Height="16"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Top"
                                     Margin="0,2,12,0">
                                <Path x:Name="IconPath"
                                      Fill="{DynamicResource Antd.Brush.InfoIcon}"
                                      Data="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm32 664c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V456c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272zm-32-384a48 48 0 1 1 0-96 48 48 0 0 1 0 96z" />
                            </Viewbox>

                            <!-- Content Area -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ContentPresenter x:Name="MessagePresenter"
                                                  ContentSource="Message"
                                                  Margin="0,0,0,4"
                                                  TextElement.FontWeight="Medium" />
                                <ContentPresenter x:Name="DescriptionPresenter"
                                                  ContentSource="Description"
                                                  Visibility="Collapsed"
                                                  TextElement.Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                                  TextElement.FontSize="12" />
                            </StackPanel>

                            <!-- Close Button -->
                            <Button x:Name="CloseButton"
                                    Grid.Column="2"
                                    Width="16"
                                    Height="16"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Top"
                                    Margin="0,2,0,0"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    BorderThickness="0">
                                <Path Width="10"
                                      Height="10"
                                      Fill="{DynamicResource Antd.Brush.TextSecondary}"
                                      Data="M563.8 512l262.5-312.9c4.4-5.2.7-13.1-6.1-13.1h-79.8c-4.7 0-9.2 2.1-12.3 5.7L511.6 449.6 295.1 191.7c-3-3.6-7.5-5.7-12.3-5.7H203c-6.8 0-10.5 7.9-6.1 13.1L459.4 512 196.9 824.9A7.95 7.95 0 0 0 203 838h79.8c4.7 0 9.2-2.1 12.3-5.7l216.5-258.1 216.5 258.1c3 3.6 7.5 5.7 12.3 5.7h79.8c6.8 0 10.5-7.9 6.1-13.1L563.8 512z" />
                            </Button>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- IsClosed Trigger -->
                        <Trigger Property="IsClosed" Value="True">
                            <Setter TargetName="RootBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- ShowIcon Trigger -->
                        <Trigger Property="ShowIcon" Value="True">
                            <Setter TargetName="IconContainer" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Description Trigger -->
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="MessagePresenter" Property="Margin" Value="0" />
                        </Trigger>

                        <!-- Closable Trigger -->
                        <Trigger Property="Closable" Value="True">
                            <Setter TargetName="CloseButton" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Type Triggers -->
                        <Trigger Property="Type" Value="Success">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.SuccessBackground}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.SuccessBorder}" />
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.SuccessIcon}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm193.5 301.7l-210.6 292a31.8 31.8 0 0 1-51.7 0L318.5 484.9c-3.8-5.3 0-12.7 6.5-12.7h46.9c10.2 0 19.9 4.9 25.9 13.3l71.2 98.8 157.2-218c6-8.3 15.6-13.3 25.9-13.3H699c6.5 0 10.3 7.4 6.5 12.7z" />
                        </Trigger>
                        <Trigger Property="Type" Value="Warning">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.WarningBackground}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.WarningBorder}" />
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.WarningIcon}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48 48 0 1 1 0-96 48 48 0 0 1 0 96z" />
                        </Trigger>
                        <Trigger Property="Type" Value="Error">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.ErrorBackground}" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.ErrorBorder}" />
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.ErrorIcon}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm165.4 618.2l-66-.3L512 563.6l-99.3 118.4-66.1.3L512 404.8l165.4 218.4z" />
                        </Trigger>

                        <!-- Banner Mode -->
                        <Trigger Property="Banner" Value="True">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="0" />
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Spin Styles -->
    <Style TargetType="{x:Type local:Spin}">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Spin}">
                    <Grid>
                        <!-- Content Layer -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          ContentSource="Content" />

                        <!-- Loading Overlay -->
                        <Border x:Name="LoadingOverlay"
                                Background="#80FFFFFF"
                                Visibility="Collapsed">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Default Spinner -->
                                <Grid x:Name="DefaultSpinner" Width="32" Height="32">
                                    <Ellipse Width="32" Height="32" Stroke="{DynamicResource Antd.Brush.Border}" StrokeThickness="3" />
                                    <Path Fill="{DynamicResource Antd.Brush.Primary}">
                                        <Path.Data>
                                            <PathGeometry Figures="M16 0 A16 16 0 0 1 32 16">
                                                <PathGeometry.Transform>
                                                    <RotateTransform x:Name="SpinnerRotate" CenterX="16" CenterY="16" Angle="0" />
                                                </PathGeometry.Transform>
                                            </PathGeometry>
                                        </Path.Data>
                                    </Path>
                                    <Grid.Triggers>
                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                     Storyboard.TargetProperty="Angle"
                                                                     From="0" To="360" Duration="0:0:1" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Grid.Triggers>
                                </Grid>

                                <!-- Custom Indicator -->
                                <ContentPresenter x:Name="IndicatorPresenter"
                                                  ContentSource="Indicator"
                                                  Visibility="Collapsed" />

                                <!-- Tip Text -->
                                <TextBlock x:Name="TipText"
                                           Text="{TemplateBinding Tip}"
                                           FontSize="14"
                                           Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"
                                           Visibility="Collapsed" />
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- IsSpinning Trigger -->
                        <Trigger Property="IsSpinning" Value="True">
                            <Setter TargetName="LoadingOverlay" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <!-- Has Content Trigger -->
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LoadingOverlay" Property="Background" Value="Transparent" />
                        </Trigger>

                        <!-- Has Custom Indicator -->
                        <Trigger Property="Indicator" Value="{x:Null}">
                            <Setter TargetName="DefaultSpinner" Property="Visibility" Value="Visible" />
                            <Setter TargetName="IndicatorPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- Has Tip -->
                        <Trigger Property="Tip" Value="{x:Null}">
                            <Setter TargetName="TipText" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- Size Triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter TargetName="DefaultSpinner" Property="Width" Value="20" />
                            <Setter TargetName="DefaultSpinner" Property="Height" Value="20" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter TargetName="DefaultSpinner" Property="Width" Value="48" />
                            <Setter TargetName="DefaultSpinner" Property="Height" Value="48" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress Line Style -->
    <Style x:Key="Antd.Progress.Line" TargetType="{x:Type local:Progress}">
        <Setter Property="Height" Value="20" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Progress}">
                    <Grid x:Name="RootGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Progress Track -->
                        <Border x:Name="Track"
                                Height="{TemplateBinding StrokeWidth}"
                                CornerRadius="4"
                                Background="{DynamicResource Antd.Brush.FillSecondary}"
                                VerticalAlignment="Center">
                            <Border x:Name="ProgressBar"
                                    CornerRadius="4"
                                    Background="{DynamicResource Antd.Brush.Primary}"
                                    HorizontalAlignment="Left" />
                        </Border>

                        <!-- Percent Text -->
                        <TextBlock x:Name="PercentText"
                                   Grid.Column="1"
                                   FontSize="14"
                                   Foreground="{DynamicResource Antd.Brush.Text}"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowInfo" Value="False">
                            <Setter TargetName="PercentText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="ProgressBar" Property="Background" Value="{DynamicResource Antd.Brush.Success}" />
                            <Setter TargetName="PercentText" Property="Foreground" Value="{DynamicResource Antd.Brush.Success}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Exception">
                            <Setter TargetName="ProgressBar" Property="Background" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter TargetName="PercentText" Property="Foreground" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress Circle Style -->
    <Style x:Key="Antd.Progress.Circle" TargetType="{x:Type local:Progress}">
        <Setter Property="Width" Value="120" />
        <Setter Property="Height" Value="120" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Progress}">
                    <Grid Width="{TemplateBinding CircleWidth}" Height="{TemplateBinding CircleWidth}">
                        <!-- Circle Track -->
                        <Ellipse x:Name="TrackCircle"
                                 Stroke="{DynamicResource Antd.Brush.FillSecondary}"
                                 StrokeThickness="{TemplateBinding StrokeWidth}" />

                        <!-- Circle Progress (placeholder - would need custom implementation for arc) -->
                        <Ellipse x:Name="ProgressCircle"
                                 Stroke="{DynamicResource Antd.Brush.Primary}"
                                 StrokeThickness="{TemplateBinding StrokeWidth}"
                                 Visibility="Visible" />

                        <!-- Percent Text -->
                        <TextBlock x:Name="PercentText"
                                   FontSize="24"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource Antd.Brush.Text}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowInfo" Value="False">
                            <Setter TargetName="PercentText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="ProgressCircle" Property="Stroke" Value="{DynamicResource Antd.Brush.Success}" />
                            <Setter TargetName="PercentText" Property="Foreground" Value="{DynamicResource Antd.Brush.Success}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Exception">
                            <Setter TargetName="ProgressCircle" Property="Stroke" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter TargetName="PercentText" Property="Foreground" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress Default Style (Line) -->
    <Style TargetType="{x:Type local:Progress}" BasedOn="{StaticResource Antd.Progress.Line}" />
</ResourceDictionary>