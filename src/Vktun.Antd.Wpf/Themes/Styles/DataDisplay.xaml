<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:core="clr-namespace:Vktun.Antd;assembly=Vktun.Antd.Core"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">

    <!-- Avatar Styles -->
    <Style TargetType="{x:Type local:Avatar}">
        <Setter Property="Width" Value="40" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Avatar}">
                    <Border x:Name="RootBorder"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            CornerRadius="20"
                            Background="{TemplateBinding Background}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <!-- Image -->
                            <Image x:Name="AvatarImage"
                                   Source="{TemplateBinding ImageSource}"
                                   Stretch="UniformToFill"
                                   Visibility="Collapsed" />

                            <!-- Icon -->
                            <Viewbox x:Name="IconContainer"
                                     Width="24"
                                     Height="24"
                                     Visibility="Collapsed">
                                <ContentPresenter ContentSource="Icon" />
                            </Viewbox>

                            <!-- Text -->
                            <TextBlock x:Name="AvatarText"
                                       Text="{TemplateBinding Text}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       Foreground="{TemplateBinding Foreground}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />

                            <!-- Fallback Content -->
                            <ContentPresenter x:Name="FallbackContent"
                                              Visibility="Collapsed"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Shape Trigger -->
                        <Trigger Property="Shape" Value="Square">
                            <Setter TargetName="RootBorder" Property="CornerRadius" Value="4" />
                        </Trigger>

                        <!-- Size Triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="Width" Value="24" />
                            <Setter Property="Height" Value="24" />
                            <Setter Property="FontSize" Value="12" />
                            <Setter TargetName="IconContainer" Property="Width" Value="14" />
                            <Setter TargetName="IconContainer" Property="Height" Value="14" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="Width" Value="64" />
                            <Setter Property="Height" Value="64" />
                            <Setter Property="FontSize" Value="28" />
                            <Setter TargetName="IconContainer" Property="Width" Value="36" />
                            <Setter TargetName="IconContainer" Property="Height" Value="36" />
                        </Trigger>

                        <!-- Content Priority: Image > Icon > Text > Content -->
                        <Trigger Property="ImageSource" Value="{x:Null}">
                            <Setter TargetName="AvatarImage" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="Text" Value="{x:Null}">
                            <Setter TargetName="AvatarText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FallbackContent" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="AvatarText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FallbackContent" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Skeleton Styles -->
    <SolidColorBrush x:Key="Skeleton.Background" Color="#F2F2F2" />

    <Style TargetType="{x:Type local:Skeleton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Skeleton}">
                    <Grid>
                        <!-- Loading State -->
                        <Grid x:Name="SkeletonContainer" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Avatar Placeholder -->
                            <Border x:Name="AvatarPlaceholder"
                                    Width="{TemplateBinding AvatarSize}"
                                    Height="{TemplateBinding AvatarSize}"
                                    CornerRadius="20"
                                    Background="{StaticResource Skeleton.Background}"
                                    Margin="0,0,16,0"
                                    Visibility="Collapsed"
                                    VerticalAlignment="Top" />

                            <!-- Content Placeholders -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <!-- Title Placeholder -->
                                <Border x:Name="TitlePlaceholder"
                                        Height="16"
                                        Width="{TemplateBinding TitleWidth}"
                                        Background="{StaticResource Skeleton.Background}"
                                        CornerRadius="4"
                                        Margin="0,0,0,16"
                                        Visibility="Collapsed" />

                                <!-- Paragraph Placeholders -->
                                <StackPanel x:Name="ParagraphContainer" Visibility="Collapsed">
                                    <!-- Rows will be generated dynamically or fixed for now -->
                                    <Border Height="16" Background="{StaticResource Skeleton.Background}" CornerRadius="4" Margin="0,0,0,8" />
                                    <Border Height="16" Background="{StaticResource Skeleton.Background}" CornerRadius="4" Margin="0,0,0,8" />
                                    <Border Height="16" Width="180" Background="{StaticResource Skeleton.Background}" CornerRadius="4" HorizontalAlignment="Left" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <!-- Actual Content -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          ContentSource="Content"
                                          Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Loading" Value="False">
                            <Setter TargetName="SkeletonContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Avatar" Value="True">
                            <Setter TargetName="AvatarPlaceholder" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="AvatarShape" Value="Square">
                            <Setter TargetName="AvatarPlaceholder" Property="CornerRadius" Value="4" />
                        </Trigger>

                        <Trigger Property="Title" Value="True">
                            <Setter TargetName="TitlePlaceholder" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Paragraph" Value="True">
                            <Setter TargetName="ParagraphContainer" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Result Styles -->
    <Style TargetType="{x:Type local:Result}">
        <Setter Property="Padding" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Result}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Icon -->
                        <Viewbox x:Name="IconContainer" Width="72" Height="72" Margin="0,0,0,24">
                            <Path x:Name="IconPath"
                                  Fill="{DynamicResource Antd.Brush.Primary}"
                                  Data="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm32 664c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V456c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272zm-32-384a48 48 0 1 1 0-96 48 48 0 0 1 0 96z" />
                        </Viewbox>

                        <!-- Custom Icon -->
                        <ContentPresenter x:Name="CustomIcon"
                                          ContentSource="Icon"
                                          Visibility="Collapsed" />

                        <!-- Title -->
                        <ContentPresenter x:Name="TitlePresenter"
                                          ContentSource="Title"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,16"
                                          TextElement.FontSize="24"
                                          TextElement.FontWeight="Medium" />

                        <!-- SubTitle -->
                        <ContentPresenter x:Name="SubTitlePresenter"
                                          ContentSource="SubTitle"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,24"
                                          TextElement.Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                          TextElement.FontSize="14" />

                        <!-- Extra -->
                        <ContentPresenter x:Name="ExtraPresenter"
                                          ContentSource="Extra"
                                          HorizontalAlignment="Center" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="CustomIcon" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.Success}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm193.5 301.7l-210.6 292a31.8 31.8 0 0 1-51.7 0L318.5 484.9c-3.8-5.3 0-12.7 6.5-12.7h46.9c10.2 0 19.9 4.9 25.9 13.3l71.2 98.8 157.2-218c6-8.3 15.6-13.3 25.9-13.3H699c6.5 0 10.3 7.4 6.5 12.7z" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm165.4 618.2l-66-.3L512 563.6l-99.3 118.4-66.1.3L512 404.8l165.4 218.4z" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.Warning}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm-32 232c0-4.4 3.6-8 8-8h48c4.4 0 8 3.6 8 8v272c0 4.4-3.6 8-8 8h-48c-4.4 0-8-3.6-8-8V296zm32 440a48 48 0 1 1 0-96 48 48 0 0 1 0 96z" />
                        </Trigger>
                        <Trigger Property="Status" Value="NotFound">
                            <Setter TargetName="IconPath" Property="Fill" Value="{DynamicResource Antd.Brush.TextSecondary}" />
                            <Setter TargetName="IconPath" Property="Data" Value="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372zm159.5-208.2L512 512l-159.5 163.8c-3.8 5.3 0 12.7 6.5 12.7h47.9c10.3 0 19.9-4.9 25.9-13.3l79.2-98.8 79.2 98.8c6 8.3 15.6 13.3 25.9 13.3H665c6.5 0 10.3-7.4 6.5-12.7z" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Empty Styles -->
    <Style TargetType="{x:Type local:Empty}">
        <Setter Property="Padding" Value="32" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Empty}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Image/Icon -->
                        <ContentPresenter x:Name="ImagePresenter"
                                          ContentSource="Image"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,16" />

                        <!-- Default Empty Icon -->
                        <Viewbox x:Name="DefaultImage" Width="64" Height="64" Margin="0,0,0,16">
                            <Path Fill="{DynamicResource Antd.Brush.TextSecondary}"
                                  Data="M512 64C264.6 64 64 264.6 64 512s200.6 448 448 448 448-200.6 448-448S759.4 64 512 64zm0 820c-205.4 0-372-166.6-372-372s166.6-372 372-372 372 166.6 372 372-166.6 372-372 372zm159.5-208.2L512 512l-159.5 163.8c-3.8 5.3 0 12.7 6.5 12.7h47.9c10.3 0 19.9-4.9 25.9-13.3l79.2-98.8 79.2 98.8c6 8.3 15.6 13.3 25.9 13.3H665c6.5 0 10.3-7.4 6.5-12.7z" />
                        </Viewbox>

                        <!-- Description -->
                        <ContentPresenter x:Name="DescriptionPresenter"
                                          ContentSource="Description"
                                          HorizontalAlignment="Center"
                                          TextElement.FontSize="14"
                                          TextElement.Foreground="{DynamicResource Antd.Brush.TextSecondary}" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Image" Value="{x:Null}">
                            <Setter TargetName="ImagePresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tag Styles -->
    <Style TargetType="{x:Type local:Tag}">
        <Setter Property="Height" Value="22" />
        <Setter Property="Padding" Value="4,0" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Cursor" Value="Arrow" />
        <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTagDefaultBackground}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushTagDefaultForeground}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tag}">
                    <Border x:Name="TagBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Color" Value="Blue">
                            <Setter TargetName="TagBorder" Property="Background" Value="#E6F7FF" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#91D5FF" />
                            <Setter Property="Foreground" Value="#1890FF" />
                        </Trigger>
                        <Trigger Property="Color" Value="Green">
                            <Setter TargetName="TagBorder" Property="Background" Value="#F6FFED" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#B7EB8F" />
                            <Setter Property="Foreground" Value="#52C41A" />
                        </Trigger>
                        <Trigger Property="Color" Value="Red">
                            <Setter TargetName="TagBorder" Property="Background" Value="#FFF1F0" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FFA39E" />
                            <Setter Property="Foreground" Value="#F5222D" />
                        </Trigger>
                        <Trigger Property="Color" Value="Orange">
                            <Setter TargetName="TagBorder" Property="Background" Value="#FFF7E6" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FFD591" />
                            <Setter Property="Foreground" Value="#FA8C16" />
                        </Trigger>
                        <Trigger Property="Color" Value="Success">
                            <Setter TargetName="TagBorder" Property="Background" Value="#F6FFED" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#B7EB8F" />
                            <Setter Property="Foreground" Value="#52C41A" />
                        </Trigger>
                        <Trigger Property="Color" Value="Warning">
                            <Setter TargetName="TagBorder" Property="Background" Value="#FFF7E6" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FFD591" />
                            <Setter Property="Foreground" Value="#FA8C16" />
                        </Trigger>
                        <Trigger Property="Color" Value="Error">
                            <Setter TargetName="TagBorder" Property="Background" Value="#FFF1F0" />
                            <Setter TargetName="TagBorder" Property="BorderBrush" Value="#FFA39E" />
                            <Setter Property="Foreground" Value="#F5222D" />
                        </Trigger>
                        <Trigger Property="Borderless" Value="True">
                            <Setter TargetName="TagBorder" Property="BorderThickness" Value="0" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ant Design Table Style -->
    <Style TargetType="{x:Type local:Table}">
        <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorderSecondary}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="RowBackground" Value="Transparent" />
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillTertiary}}" />
        <Setter Property="HeadersVisibility" Value="Column" />
        <Setter Property="GridLinesVisibility" Value="None" />
        <Setter Property="CanUserAddRows" Value="False" />
        <Setter Property="CanUserDeleteRows" Value="False" />
        <Setter Property="AutoGenerateColumns" Value="False" />
        <Setter Property="IsReadOnly" Value="True" />
        <Setter Property="RowHeight" Value="55" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="ColumnHeaderStyle">
            <Setter.Value>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBgContainer}}" />
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushText}}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorderSecondary}}" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="16,8" />
                    <Setter Property="FontWeight" Value="SemiBold" />
                    <Setter Property="FontSize" Value="14" />
                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                    <Setter Property="VerticalContentAlignment" Value="Center" />
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="RowStyle">
            <Setter.Value>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="Transparent" />
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushBorderSecondary}}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                    <Setter Property="FontSize" Value="14" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushFillSecondary}}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="{DynamicResource {x:Static core:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="CellStyle">
            <Setter.Value>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="Padding" Value="16,8" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                </Style>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>