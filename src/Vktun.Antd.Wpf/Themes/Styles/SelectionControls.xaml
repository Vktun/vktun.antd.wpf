<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">

    <!-- Switch Styles -->
    <Style TargetType="local:Switch">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:Switch">
                    <ControlTemplate.Resources>
                        <Storyboard x:Key="CheckedStoryboard">
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="22,2,2,2"
                                                Duration="0:0:0.2" />
                        </Storyboard>
                        <Storyboard x:Key="UncheckedStoryboard">
                            <ThicknessAnimation Storyboard.TargetName="Thumb"
                                                Storyboard.TargetProperty="Margin"
                                                To="2,2,22,2"
                                                Duration="0:0:0.2" />
                        </Storyboard>
                    </ControlTemplate.Resources>
                    <Grid>
                        <Border x:Name="SwitchBorder"
                                CornerRadius="10"
                                Background="#BFBFBF"
                                BorderThickness="0">
                            <Grid>
                                <TextBlock x:Name="CheckedText"
                                           Text="{TemplateBinding CheckedChildren}"
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Visibility="Collapsed" />
                                <TextBlock x:Name="UncheckedText"
                                           Text="{TemplateBinding UnCheckedChildren}"
                                           Foreground="White"
                                           FontSize="12"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <Border x:Name="Thumb"
                                Width="18"
                                Height="18"
                                Margin="2,2,22,2"
                                CornerRadius="9"
                                Background="White"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="2" ShadowDepth="0" Opacity="0.3" />
                            </Border.Effect>
                        </Border>
                        <Border x:Name="LoadingOverlay"
                                Width="18"
                                Height="18"
                                Margin="2,2,22,2"
                                CornerRadius="9"
                                Background="White"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <local:Spin Width="14" Height="14" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource CheckedStoryboard}" />
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard Storyboard="{StaticResource UncheckedStoryboard}" />
                            </Trigger.ExitActions>
                            <Setter TargetName="SwitchBorder" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="CheckedText" Property="Visibility" Value="Visible" />
                            <Setter TargetName="UncheckedText" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="False">
                            <Setter TargetName="SwitchBorder" Property="Background" Value="#BFBFBF" />
                            <Setter TargetName="CheckedText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="UncheckedText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="SwitchBorder" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </MultiTrigger>
                        <Trigger Property="IsLoading" Value="True">
                            <Setter TargetName="Thumb" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LoadingOverlay" Property="Visibility" Value="Visible" />
                            <Setter Property="Cursor" Value="Wait" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <!-- Size triggers -->
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="Width" Value="28" />
                            <Setter Property="Height" Value="16" />
                            <Setter TargetName="Thumb" Property="Width" Value="12" />
                            <Setter TargetName="Thumb" Property="Height" Value="12" />
                            <Setter TargetName="Thumb" Property="CornerRadius" Value="6" />
                            <Setter TargetName="SwitchBorder" Property="CornerRadius" Value="8" />
                            <Setter TargetName="LoadingOverlay" Property="Width" Value="12" />
                            <Setter TargetName="LoadingOverlay" Property="Height" Value="12" />
                            <Setter TargetName="LoadingOverlay" Property="CornerRadius" Value="6" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="Width" Value="56" />
                            <Setter Property="Height" Value="28" />
                            <Setter TargetName="Thumb" Property="Width" Value="22" />
                            <Setter TargetName="Thumb" Property="Height" Value="22" />
                            <Setter TargetName="Thumb" Property="CornerRadius" Value="11" />
                            <Setter TargetName="SwitchBorder" Property="CornerRadius" Value="14" />
                            <Setter TargetName="LoadingOverlay" Property="Width" Value="22" />
                            <Setter TargetName="LoadingOverlay" Property="Height" Value="22" />
                            <Setter TargetName="LoadingOverlay" Property="CornerRadius" Value="11" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box"
                                Width="18"
                                Height="18"
                                Margin="0,0,10,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}"
                                BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Path x:Name="Check"
                                  Width="10"
                                  Height="8"
                                  Stretch="Fill"
                                  Visibility="Collapsed"
                                  Data="M 0 4 L 3 7 L 10 0"
                                  Stroke="White"
                                  StrokeThickness="2" />
                        </Border>
                        <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid Width="18" Height="18" Margin="0,0,10,0">
                            <Ellipse x:Name="Outer"
                                     StrokeThickness="1"
                                     Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}"
                                     Fill="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
                            <Ellipse x:Name="Inner"
                                     Width="8"
                                     Height="8"
                                     Fill="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}"
                                     Visibility="Collapsed" />
                        </Grid>
                        <ContentPresenter Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Inner" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabControl">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TabPanel Grid.Row="0"
                                  Background="Transparent"
                                  Margin="0,0,0,16"
                                  IsItemsHost="True" />
                        <Border Grid.Row="1"
                                Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}"
                                CornerRadius="12"
                                Padding="20"
                                BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                                BorderThickness="1">
                            <ContentPresenter ContentSource="SelectedContent" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,0,12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="Root"
                            Padding="14,10"
                            Background="Transparent"
                            CornerRadius="10">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
                            <Setter TargetName="Root" Property="Effect" Value="{DynamicResource {x:Static local:AntdResourceKeys.ShadowCard}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ant Design Checkbox Styles -->
    <Style TargetType="{x:Type local:Checkbox}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Checkbox}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border x:Name="Box"
                                Width="16"
                                Height="16"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}"
                                BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}"
                                BorderThickness="1"
                                CornerRadius="2">
                            <Grid>
                                <!-- Check mark -->
                                <Path x:Name="Check"
                                      Width="10"
                                      Height="8"
                                      Stretch="Fill"
                                      Visibility="Collapsed"
                                      Data="M 0 4 L 3 7 L 10 0"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                                <!-- Indeterminate dash -->
                                <Rectangle x:Name="Indeterminate"
                                           Width="10"
                                           Height="2"
                                           Fill="White"
                                           Visibility="Collapsed"
                                           RadiusX="1"
                                           RadiusY="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ContentPresenter Grid.Column="1"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="Box" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Indeterminate" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- CheckboxGroup Styles -->
    <Style TargetType="{x:Type local:CheckboxGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CheckboxGroup}">
                    <StackPanel Orientation="Horizontal">
                        <ItemsPresenter />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <local:Checkbox Content="{Binding}"
                                   Tag="{Binding}"
                                   Margin="0,0,8,0" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ant Design Radio Styles -->
    <Style TargetType="{x:Type local:Radio}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Radio}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Default circle style -->
                        <Grid x:Name="CircleContainer" Width="16" Height="16" Margin="0,0,8,0">
                            <Ellipse x:Name="Outer"
                                     StrokeThickness="1"
                                     Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}"
                                     Fill="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
                            <Ellipse x:Name="Inner"
                                     Width="8"
                                     Height="8"
                                     Fill="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}"
                                     Visibility="Collapsed" />
                        </Grid>
                        <!-- Button style -->
                        <Border x:Name="ButtonContainer"
                                Visibility="Collapsed"
                                Background="Transparent"
                                BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}"
                                BorderThickness="1"
                                Padding="12,4"
                                CornerRadius="0"
                                Margin="-1,0,0,0">
                            <ContentPresenter VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <!-- Default content presenter -->
                        <ContentPresenter x:Name="DefaultContent"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Default style triggers -->
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Inner" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Outer" Property="Stroke" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>

                        <!-- Button style triggers -->
                        <Trigger Property="ButtonStyle" Value="Outline">
                            <Setter TargetName="CircleContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ButtonContainer" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DefaultContent" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ButtonStyle" Value="Solid">
                            <Setter TargetName="CircleContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ButtonContainer" Property="Visibility" Value="Visible" />
                            <Setter TargetName="DefaultContent" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <!-- Outline button checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ButtonStyle" Value="Outline" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ButtonContainer" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="ButtonContainer" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger>

                        <!-- Solid button checked -->
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="ButtonStyle" Value="Solid" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="ButtonContainer" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="ButtonContainer" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter Property="Foreground" Value="White" />
                        </MultiTrigger>

                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- RadioGroup Styles -->
    <Style TargetType="{x:Type local:RadioGroup}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:RadioGroup}">
                    <StackPanel Orientation="Horizontal">
                        <ItemsPresenter />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <local:Radio Content="{Binding}"
                                Tag="{Binding}"
                                Margin="0,0,8,0" />
                </DataTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
