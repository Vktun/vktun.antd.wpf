<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">

    <!-- Divider Styles -->
    <Style TargetType="{x:Type local:Divider}">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.Border}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Divider}">
                    <Grid>
                        <!-- Horizontal Divider -->
                        <Grid x:Name="HorizontalContainer" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border x:Name="LeftLine"
                                    Height="1"
                                    Background="{TemplateBinding Background}"
                                    VerticalAlignment="Center" />

                            <ContentPresenter x:Name="TextPresenter"
                                              Grid.Column="1"
                                              ContentSource="Content"
                                              Margin="16,0"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed" />

                            <Border x:Name="RightLine"
                                    Grid.Column="2"
                                    Height="1"
                                    Background="{TemplateBinding Background}"
                                    VerticalAlignment="Center" />
                        </Grid>

                        <!-- Vertical Divider -->
                        <Border x:Name="VerticalLine"
                                Width="1"
                                Background="{TemplateBinding Background}"
                                HorizontalAlignment="Center"
                                Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Orientation Trigger -->
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource TemplatedParent}}" Value="Vertical">
                            <Setter TargetName="HorizontalContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VerticalLine" Property="Visibility" Value="Visible" />
                            <Setter Property="Height" Value="Auto" />
                            <Setter Property="Width" Value="1" />
                        </DataTrigger>

                        <!-- Dashed Trigger -->
                        <DataTrigger Binding="{Binding Dashed, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="LeftLine" Property="BorderBrush" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="LeftLine" Property="BorderThickness" Value="0,1,0,1" />
                            <Setter TargetName="LeftLine" Property="Background" Value="Transparent" />
                            <Setter TargetName="RightLine" Property="BorderBrush" Value="{Binding Background, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="RightLine" Property="BorderThickness" Value="0,1,0,1" />
                            <Setter TargetName="RightLine" Property="Background" Value="Transparent" />
                        </DataTrigger>

                        <!-- Has Content Trigger -->
                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="TextPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LeftLine" Property="HorizontalAlignment" Value="Stretch" />
                            <Setter TargetName="RightLine" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}" Value="">
                            <Setter TargetName="TextPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LeftLine" Property="HorizontalAlignment" Value="Stretch" />
                            <Setter TargetName="RightLine" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>

                        <!-- Text Placement Triggers -->
                        <DataTrigger Binding="{Binding TextPlacement, RelativeSource={RelativeSource TemplatedParent}}" Value="Left">
                            <Setter TargetName="LeftLine" Property="Width" Value="50" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding TextPlacement, RelativeSource={RelativeSource TemplatedParent}}" Value="Right">
                            <Setter TargetName="RightLine" Property="Width" Value="50" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Breadcrumb Styles -->
    <Style TargetType="{x:Type local:Breadcrumb}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Breadcrumb}">
                    <ItemsPresenter />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:BreadcrumbItem}">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:BreadcrumbItem}">
                    <StackPanel Orientation="Horizontal">
                        <ContentPresenter x:Name="IconPresenter"
                                          ContentSource="Icon"
                                          Margin="0,0,4,0"
                                          Visibility="Collapsed" />
                        <ContentPresenter x:Name="HeaderPresenter"
                                          ContentSource="Header"
                                          VerticalAlignment="Center" />
                        <ContentPresenter x:Name="SeparatorPresenter"
                                          Content="{Binding Separator, RelativeSource={RelativeSource AncestorType=local:Breadcrumb}}"
                                          Margin="8,0"
                                          TextElement.Foreground="{DynamicResource Antd.Brush.TextSecondary}"
                                          Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                            <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLast, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="SeparatorPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="HeaderPresenter" Property="TextElement.Foreground" Value="{DynamicResource Antd.Brush.Text}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLast, RelativeSource={RelativeSource TemplatedParent}}" Value="False">
                            <Setter TargetName="HeaderPresenter" Property="TextElement.Foreground" Value="{DynamicResource Antd.Brush.TextSecondary}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Collapse Styles -->
    <Style TargetType="{x:Type local:Collapse}">
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Collapse}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource Antd.BorderRadius.Md}">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:CollapsePanel}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:CollapsePanel}">
                    <StackPanel>
                        <!-- Header -->
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                Padding="16,12"
                                Cursor="Hand">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Expand Icon -->
                                <Path x:Name="ExpandIcon"
                                      Grid.Column="0"
                                      Width="12"
                                      Height="12"
                                      Margin="0,0,12,0"
                                      Fill="{DynamicResource Antd.Brush.Text}"
                                      Data="M765.7 486.8L314.9 134.7A7.97 7.97 0 0 0 302 141v77.3c0 4.9 2.3 9.6 6.1 12.6l360 281.1-360 281.1c-3.9 3-6.1 7.7-6.1 12.6V883c0 6.7 7.7 10.4 12.9 6.3l450.8-352.1a31.96 31.96 0 0 0 0-50.4z"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform Angle="0" />
                                    </Path.RenderTransform>
                                </Path>

                                <!-- Header Content -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center" />

                                <!-- Extra Content -->
                                <ContentPresenter Grid.Column="2"
                                                  ContentSource="Extra"
                                                  VerticalAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Content -->
                        <Border x:Name="ContentBorder"
                                Background="{DynamicResource Antd.Brush.FillSecondary}"
                                Padding="16"
                                Visibility="Collapsed">
                            <ContentPresenter ContentSource="Content" />
                        </Border>

                        <!-- Bottom Border -->
                        <Border x:Name="BottomBorder"
                                Height="1"
                                Background="{DynamicResource Antd.Brush.Border}"
                                Visibility="Visible" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="ContentBorder" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ExpandIcon" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Disabled, RelativeSource={RelativeSource TemplatedParent}}" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Cursor" Value="No" />
                            <Setter TargetName="HeaderBorder" Property="Opacity" Value="0.5" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Space Styles -->
    <Style TargetType="{x:Type local:Space}">
        <Setter Property="HorizontalAlignment" Value="{Binding Align, RelativeSource={RelativeSource Self}}" />
    </Style>

    <!-- Grid (Row / Col) Styles -->
    <Style TargetType="{x:Type local:Row}">
        <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style TargetType="{x:Type local:Col}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Col}">
                    <ContentPresenter ContentSource="Content"
                                      Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
