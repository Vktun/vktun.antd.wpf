<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf">

    <!-- Timeline Styles -->
    <Style TargetType="{x:Type local:TimelineItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:TimelineItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Label (Left) -->
                        <ContentPresenter x:Name="LabelPresenter"
                                          Grid.Column="0"
                                          Margin="0,0,16,0"
                                          VerticalAlignment="Top"
                                          Content="{TemplateBinding Label}" />
                        <!-- Dot + Line -->
                        <Grid Grid.Column="1" Margin="0,4,0,0">
                            <!-- Dot -->
                            <Border x:Name="DotBorder"
                                    Width="10"
                                    Height="10"
                                    Background="{DynamicResource Antd.Brush.Primary}"
                                    BorderBrush="{DynamicResource Antd.Brush.Primary}"
                                    BorderThickness="2"
                                    CornerRadius="5"
                                    VerticalAlignment="Top">
                                <ContentPresenter x:Name="CustomDot"
                                                  Content="{TemplateBinding Dot}" />
                            </Border>
                            <!-- Line -->
                            <Border x:Name="LineBorder"
                                    Width="2"
                                    Height="Auto"
                                    Background="{DynamicResource Antd.Brush.BorderSecondary}"
                                    Visibility="Visible"
                                    VerticalAlignment="Stretch"
                                    Margin="0,12,0,0" />
                        </Grid>
                        <!-- Content -->
                        <ContentPresenter x:Name="ContentPresenter"
                                          Grid.Column="2"
                                          Margin="16,0,0,0"
                                          VerticalAlignment="Top"
                                          Content="{TemplateBinding Content}" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Color" Value="Red">
                            <Setter TargetName="DotBorder" Property="Background" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter TargetName="DotBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Green">
                            <Setter TargetName="DotBorder" Property="Background" Value="{DynamicResource Antd.Brush.Success}" />
                            <Setter TargetName="DotBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.Success}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Gray">
                            <Setter TargetName="DotBorder" Property="Background" Value="{DynamicResource Antd.Brush.TextTertiary}" />
                            <Setter TargetName="DotBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.TextTertiary}" />
                        </Trigger>
                        <Trigger Property="Dot" Value="{x:Null}">
                            <Setter TargetName="CustomDot" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Label" Value="{x:Null}">
                            <Setter TargetName="LabelPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsLast" Value="True">
                            <Setter TargetName="LineBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Position" Value="Right">
                            <Setter TargetName="LabelPresenter" Property="Grid.Column" Value="2" />
                            <Setter TargetName="ContentPresenter" Property="Grid.Column" Value="0" />
                            <Setter TargetName="LabelPresenter" Property="Margin" Value="16,0,0,0" />
                            <Setter TargetName="ContentPresenter" Property="Margin" Value="0,0,16,0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Timeline}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Vertical" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Timeline}">
                    <StackPanel Orientation="Vertical" Margin="0,0,0,20">
                        <ItemsPresenter />
                        <!-- Pending Ghost -->
                        <Grid x:Name="PendingContainer" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              Margin="0,0,16,0" />
                            <Border Grid.Column="1"
                                    Width="10"
                                    Height="10"
                                    Background="{DynamicResource Antd.Brush.TextTertiary}"
                                    BorderBrush="{DynamicResource Antd.Brush.TextTertiary}"
                                    BorderThickness="2"
                                    CornerRadius="5"
                                    VerticalAlignment="Top">
                                <ContentPresenter Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=PendingDot}" />
                            </Border>
                            <ContentPresenter Grid.Column="2"
                                              Margin="16,0,0,0"
                                              Content="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=Pending}" />
                        </Grid>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Pending" Value="{x:Null}">
                            <Setter TargetName="PendingContainer" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- List Styles -->
    <Style TargetType="{x:Type local:ListItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:ListItem}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}" />
                            <ContentPresenter x:Name="ExtraPresenter"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Extra}" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Content" Value="{x:Null}">
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Extra" Value="{x:Null}">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsHoverable" Value="True">
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Antd.Brush.FillSecondary}" />
                            </Trigger>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:List}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="{DynamicResource Antd.Brush.BgContainer}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Antd.Brush.BorderSecondary}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:List}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                        <StackPanel Orientation="Vertical">
                            <!-- Header -->
                            <Border x:Name="HeaderBorder"
                                    Padding="12"
                                    BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                    BorderThickness="0,0,0,1"
                                    Visibility="Collapsed">
                                <ContentPresenter Content="{TemplateBinding Header}" />
                            </Border>
                            <!-- Items -->
                            <ItemsPresenter Margin="0,12,0,0" />
                            <!-- Footer -->
                            <Border x:Name="FooterBorder"
                                    Padding="12"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                                <ContentPresenter Content="{TemplateBinding Footer}" />
                            </Border>
                            <!-- Load More -->
                            <Border x:Name="LoadMoreBorder"
                                    Padding="12"
                                    Margin="0,12,0,0"
                                    Visibility="Collapsed">
                                <ContentPresenter Content="{TemplateBinding LoadMore}" />
                            </Border>
                            <!-- Loading -->
                            <local:Spin x:Name="LoadingSpin"
                                        Margin="0,12,0,12"
                                        Visibility="Collapsed" />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Header" Value="{x:Null}">
                            <Setter TargetName="HeaderBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Footer" Value="{x:Null}">
                            <Setter TargetName="FooterBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="LoadMore" Value="{x:Null}">
                            <Setter TargetName="LoadMoreBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Loading" Value="True">
                            <Setter TargetName="LoadingSpin" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Bordered" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="1" />
                        </Trigger>
                        <Trigger Property="Split" Value="False">
                            <Style TargetType="local:ListItem">
                                <Setter Property="BorderThickness" Value="0" />
                            </Style>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Descriptions Styles -->
    <Style x:Key="Antd.DescriptionLabelStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.TextTertiary}" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style x:Key="Antd.DescriptionContentStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource Antd.Brush.Text}" />
        <Setter Property="Padding" Value="16,12" />
    </Style>

    <Style TargetType="{x:Type local:DescriptionItem}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DescriptionItem}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Label -->
                        <Border x:Name="LabelBorder"
                                Grid.Column="0"
                                Background="{DynamicResource Antd.Brush.FillSecondary}"
                                Padding="16,12">
                            <TextBlock Foreground="{DynamicResource Antd.Brush.TextTertiary}"
                                       FontWeight="Medium"
                                       Text="{Binding Label, RelativeSource={RelativeSource TemplatedParent}}" />
                        </Border>
                        <!-- Content -->
                        <Border x:Name="ContentBorder"
                                Grid.Column="1"
                                Background="{DynamicResource Antd.Brush.BgContainer}"
                                Padding="16,12">
                            <ContentPresenter Content="{TemplateBinding Content}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Descriptions}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="{Binding RelativeSource={RelativeSource AncestorType={x:Type local:Descriptions}}, Path=Column}" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <local:DescriptionItem />
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Descriptions}">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource Antd.Brush.Border}"
                            BorderThickness="0"
                            CornerRadius="8">
                        <StackPanel Orientation="Vertical">
                            <!-- Header -->
                            <Grid x:Name="HeaderContainer" Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="TitlePresenter"
                                                  Grid.Column="0" />
                                <ContentPresenter x:Name="ExtraPresenter"
                                                  Grid.Column="2" />
                            </Grid>
                            <!-- Items Container -->
                            <ItemsPresenter />
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Extra" Value="{x:Null}">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Bordered" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="1" />
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource Antd.Brush.BorderSecondary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tooltip Styles -->
    <Style TargetType="{x:Type local:Tooltip}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tooltip}">
                    <Grid>
                        <ContentPresenter x:Name="TriggerContent"
                                          ContentSource="Content" />
                        <Popup x:Name="TooltipPopup"
                               Placement="{TemplateBinding Placement}"
                               IsOpen="{TemplateBinding IsOpen}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=TriggerContent}">
                            <Border x:Name="TooltipBorder"
                                    Background="#4B5563"
                                    Padding="8,6"
                                    CornerRadius="4"
                                    Effect="{DynamicResource Antd.Shadow.Popup}">
                                <Grid>
                                    <ContentPresenter x:Name="TitlePresenter"
                                                      Content="{TemplateBinding Title}" />
                                    <!-- Arrow -->
                                    <Path x:Name="ArrowPath"
                                          Width="8"
                                          Height="8"
                                          Fill="#4B5563"
                                          Data="M 0 8 L 4 0 L 8 8"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Bottom"
                                          Margin="0,-4,0,0" />
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Arrow" Value="True">
                            <Setter TargetName="ArrowPath" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Color" Value="Blue">
                            <Setter TargetName="TooltipBorder" Property="Background" Value="{DynamicResource Antd.Brush.Primary}" />
                            <Setter TargetName="ArrowPath" Property="Fill" Value="{DynamicResource Antd.Brush.Primary}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Green">
                            <Setter TargetName="TooltipBorder" Property="Background" Value="{DynamicResource Antd.Brush.Success}" />
                            <Setter TargetName="ArrowPath" Property="Fill" Value="{DynamicResource Antd.Brush.Success}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Red">
                            <Setter TargetName="TooltipBorder" Property="Background" Value="{DynamicResource Antd.Brush.Error}" />
                            <Setter TargetName="ArrowPath" Property="Fill" Value="{DynamicResource Antd.Brush.Error}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Popover}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Popover}">
                    <Grid>
                        <ContentPresenter x:Name="TriggerContent"
                                          ContentSource="Content" />
                        <Popup x:Name="PopoverPopup"
                               Placement="{TemplateBinding Placement}"
                               IsOpen="{TemplateBinding IsOpen}"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding ElementName=TriggerContent}">
                            <Border x:Name="PopoverBorder"
                                    Background="{DynamicResource Antd.Brush.BgContainer}"
                                    BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                    BorderThickness="1"
                                    Padding="0"
                                    CornerRadius="8"
                                    MinWidth="{TemplateBinding OverlayMinWidth}"
                                    MaxWidth="{TemplateBinding OverlayMaxWidth}"
                                    Effect="{DynamicResource Antd.Shadow.Popup}">
                                <StackPanel Orientation="Vertical">
                                    <!-- Title -->
                                    <Border x:Name="TitleBorder"
                                            Padding="16,12"
                                            BorderBrush="{DynamicResource Antd.Brush.BorderSecondary}"
                                            BorderThickness="0,0,0,1">
                                        <ContentPresenter Content="{TemplateBinding Title}" />
                                    </Border>
                                    <!-- Content -->
                                    <Border Padding="16,12">
                                        <ContentPresenter Content="{TemplateBinding PopoverContent}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitleBorder" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>