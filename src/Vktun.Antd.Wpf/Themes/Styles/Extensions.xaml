<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:Vktun.Antd.Wpf"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Style TargetType="{x:Type local:Layout}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgLayout}}" />
        <Setter Property="LastChildFill" Value="True" />
    </Style>

    <Style TargetType="{x:Type local:LayoutHeader}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Height" Value="64" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LayoutHeader}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                            BorderThickness="0,0,0,1">
                        <ContentPresenter VerticalAlignment="Center" RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:LayoutFooter}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}" />
        <Setter Property="Padding" Value="20,16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LayoutFooter}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                            BorderThickness="1,1,1,0">
                        <ContentPresenter RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:LayoutSider}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LayoutSider}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                            BorderThickness="0,0,1,0">
                        <ContentPresenter RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:LayoutContent}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:LayoutContent}">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Splitter}">
        <Setter Property="Width" Value="8" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}" />
        <Setter Property="ShowsPreview" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Splitter}">
                    <Grid Background="{TemplateBinding Background}">
                        <Border Width="2"
                                HorizontalAlignment="Center"
                                Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                                CornerRadius="999" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Calendar}" BasedOn="{StaticResource {x:Type Calendar}}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CalendarItemStyle" Value="{DynamicResource Antd.CalendarItemStyle}" />
        <Setter Property="CalendarButtonStyle" Value="{DynamicResource Antd.CalendarButtonStyle}" />
        <Setter Property="CalendarDayButtonStyle" Value="{DynamicResource Antd.CalendarDayButtonStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Calendar}">
                    <Border Background="{TemplateBinding Background}">
                        <Grid x:Name="PART_Root">
                            <CalendarItem x:Name="PART_CalendarItem"
                                          Style="{TemplateBinding CalendarItemStyle}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:DatePicker}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightMiddle}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:DatePicker}">
                    <Grid>
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                            <Grid Margin="{TemplateBinding Padding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid>
                                    <TextBox x:Name="PART_TextBox"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Padding="0"
                                             IsReadOnly="True"
                                             Foreground="{TemplateBinding Foreground}"
                                             VerticalContentAlignment="Center" />
                                    <TextBlock x:Name="PlaceholderText"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextTertiary}}"
                                               Visibility="Collapsed"
                                               IsHitTestVisible="False"
                                               Text="{TemplateBinding Placeholder}" />
                                </Grid>
                                <Button x:Name="PART_ClearButton"
                                        Grid.Column="1"
                                        Width="24"
                                        Height="24"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed"
                                        Style="{DynamicResource Antd.DatePicker.TriggerButtonStyle}">
                                    <Path Width="10"
                                          Height="10"
                                          Data="M 1 1 L 9 9 M 9 1 L 1 9"
                                          StrokeThickness="1.4"
                                          Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextTertiary}}" />
                                </Button>
                                <Button x:Name="PART_Button"
                                        Grid.Column="2"
                                        Width="24"
                                        Height="24"
                                        Margin="8,0,0,0"
                                        Style="{DynamicResource Antd.DatePicker.TriggerButtonStyle}">
                                    <Grid Width="14" Height="14">
                                        <Rectangle RadiusX="2"
                                                   RadiusY="2"
                                                   StrokeThickness="1"
                                                   Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <Line X1="0" Y1="4" X2="14" Y2="4"
                                              StrokeThickness="1"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <Line X1="4" Y1="0" X2="4" Y2="4"
                                              StrokeThickness="1"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                        <Line X1="10" Y1="0" X2="10" Y2="4"
                                              StrokeThickness="1"
                                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                    </Grid>
                                </Button>
                            </Grid>
                        </Border>
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}">
                            <Border x:Name="PART_PopupBorder"
                                    Margin="0,8,0,0"
                                    Padding="10"
                                    Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgElevated}}"
                                    BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}"
                                    BorderThickness="1"
                                    CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusLarge}}"
                                    Effect="{DynamicResource {x:Static local:AntdResourceKeys.ShadowPopup}}">
                                <local:Calendar x:Name="PART_Calendar"
                                                Width="270"
                                                Background="Transparent"
                                                BorderThickness="0" />
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="PART_TextBox" Property="Text" Value="">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="AllowClear" Value="True">
                            <Setter TargetName="PART_ClearButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="PART_PopupBorder" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:RangePicker}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightMiddle}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:RangePicker}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding StartValue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:yyyy-MM-dd}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0"
                                       Foreground="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextTertiary}}"
                                       Text="→"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding EndValue, RelativeSource={RelativeSource TemplatedParent}, StringFormat={}{0:yyyy-MM-dd}}"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:InputNumber}">
        <Setter Property="FocusVisualStyle" Value="{DynamicResource Antd.FocusVisualStyle}" />
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorder}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightMiddle}}" />
        <Setter Property="Padding" Value="12,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:InputNumber}">
                    <Border x:Name="Border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="PrefixPresenter"
                                              Margin="0,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Prefix}" />
                            <Grid Grid.Column="1">
                                <TextBox x:Name="PART_TextBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0"
                                         VerticalContentAlignment="Center"
                                         Foreground="{TemplateBinding Foreground}" />
                                <TextBlock x:Name="PlaceholderText"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextTertiary}}"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           Text="{TemplateBinding Placeholder}" />
                            </Grid>
                            <ContentPresenter x:Name="SuffixPresenter"
                                              Grid.Column="2"
                                              Margin="8,0,8,0"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Suffix}" />
                            <Grid Grid.Column="3" Width="18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Button x:Name="PART_UpButton"
                                        Grid.Row="0"
                                        Focusable="False"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Path Width="8" Height="6" Data="M 0 6 L 4 0 L 8 6"
                                          StrokeThickness="1.4"
                                          Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}" />
                                </Button>
                                <Button x:Name="PART_DownButton"
                                        Grid.Row="1"
                                        Focusable="False"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                    <Path Width="8" Height="6" Data="M 0 0 L 4 6 L 8 0"
                                          StrokeThickness="1.4"
                                          Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}" />
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Prefix" Value="{x:Null}">
                            <Setter TargetName="PrefixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Suffix" Value="{x:Null}">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger SourceName="PART_TextBox" Property="Text" Value="">
                            <Setter TargetName="PlaceholderText" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimaryHover}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Success">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Warning">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                        </Trigger>
                        <Trigger Property="Status" Value="Error">
                            <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightSmall}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="MinHeight" Value="{DynamicResource {x:Static local:AntdResourceKeys.ControlHeightLarge}}" />
                            <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.56" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Slider.ThumbStyle" TargetType="Thumb">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Ellipse Fill="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}"
                             Stroke="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}"
                             StrokeThickness="2" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.Slider.RepeatButtonStyle" TargetType="RepeatButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="999" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Slider}">
        <Setter Property="Height" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Slider}">
                    <Grid Margin="0,6">
                        <Track x:Name="PART_Track"
                               Minimum="{TemplateBinding Minimum}"
                               Maximum="{TemplateBinding Maximum}"
                               Value="{TemplateBinding Value}"
                               Orientation="{TemplateBinding Orientation}">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Antd.Slider.RepeatButtonStyle}"
                                              Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource Antd.Slider.ThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource Antd.Slider.RepeatButtonStyle}"
                                              Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillQuaternary}}" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="Height" Value="18" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="Height" Value="30" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Antd.SegmentedItemStyle" TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}" />
        <Setter Property="Padding" Value="14,8" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Root"
                            Margin="2"
                            Padding="{TemplateBinding Padding}"
                            Background="Transparent"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusMiddle}}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBgContainer}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushText}}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillSecondary}}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ItemsPanelTemplate x:Key="Antd.Segmented.HorizontalPanel">
        <StackPanel Orientation="Horizontal" />
    </ItemsPanelTemplate>

    <ItemsPanelTemplate x:Key="Antd.Segmented.BlockPanel">
        <UniformGrid Rows="1" />
    </ItemsPanelTemplate>

    <Style TargetType="{x:Type local:Segmented}">
        <Setter Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushFillQuaternary}}" />
        <Setter Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="2" />
        <Setter Property="ItemsPanel" Value="{StaticResource Antd.Segmented.HorizontalPanel}" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource Antd.SegmentedItemStyle}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Segmented}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{DynamicResource {x:Static local:AntdResourceKeys.BorderRadiusLarge}}"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Disabled"
                                      CanContentScroll="False">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Block" Value="True">
                <Setter Property="ItemsPanel" Value="{StaticResource Antd.Segmented.BlockPanel}" />
            </Trigger>
            <Trigger Property="Size" Value="Small">
                <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeSmall}}" />
            </Trigger>
            <Trigger Property="Size" Value="Large">
                <Setter Property="FontSize" Value="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeLarge}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="{x:Type local:Statistic}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Statistic}">
                    <StackPanel>
                        <TextBlock Text="{TemplateBinding Title}"
                                   Foreground="{DynamicResource {x:Static local:AntdResourceKeys.BrushTextSecondary}}"
                                   FontSize="{DynamicResource {x:Static local:AntdResourceKeys.FontSizeBase}}" />
                        <WrapPanel Margin="0,8,0,0" VerticalAlignment="Bottom">
                            <ContentPresenter Content="{TemplateBinding Prefix}" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding FormattedValue, RelativeSource={RelativeSource TemplatedParent}}"
                                       FontSize="30"
                                       FontWeight="SemiBold" />
                            <ContentPresenter Content="{TemplateBinding Suffix}" Margin="6,0,0,0" />
                        </WrapPanel>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Watermark}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Watermark}">
                    <Grid>
                        <ContentPresenter />
                        <Rectangle Fill="{Binding WatermarkBrush, RelativeSource={RelativeSource TemplatedParent}}"
                                   IsHitTestVisible="False" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type local:Tag}">
        <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushTagDefaultForeground}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:Tag}">
                    <Border x:Name="Root"
                            Padding="10,4"
                            CornerRadius="999"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource {x:Static local:AntdResourceKeys.BrushTransparent}}"
                            Background="{DynamicResource {x:Static local:AntdResourceKeys.BrushTagDefaultBackground}}">
                        <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Color" Value="Blue">
                            <Setter TargetName="Root" Property="Background" Value="#E6F4FF" />
                            <Setter Property="Foreground" Value="#1677FF" />
                        </Trigger>
                        <Trigger Property="Color" Value="Green">
                            <Setter TargetName="Root" Property="Background" Value="#F6FFED" />
                            <Setter Property="Foreground" Value="#52C41A" />
                        </Trigger>
                        <Trigger Property="Color" Value="Red">
                            <Setter TargetName="Root" Property="Background" Value="#FFF2F0" />
                            <Setter Property="Foreground" Value="#FF4D4F" />
                        </Trigger>
                        <Trigger Property="Color" Value="Orange">
                            <Setter TargetName="Root" Property="Background" Value="#FFF7E6" />
                            <Setter Property="Foreground" Value="#FA8C16" />
                        </Trigger>
                        <Trigger Property="Color" Value="Success">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushSuccess}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWhite}}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Warning">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWarning}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWhite}}" />
                        </Trigger>
                        <Trigger Property="Color" Value="Error">
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushError}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWhite}}" />
                        </Trigger>
                        <Trigger Property="Borderless" Value="True">
                            <Setter TargetName="Root" Property="BorderThickness" Value="0" />
                        </Trigger>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushBorderSecondary}}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsCheckable" Value="True" />
                                <Condition Property="IsChecked" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushPrimary}}" />
                            <Setter Property="Foreground" Value="{DynamicResource {x:Static local:AntdResourceKeys.BrushWhite}}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
